            "EpisodeMasterId": 142401,
            "Order": 1,
            "GroupOrder": 23,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "でも初魅さんは、世界演劇リーグには興味ないみたいだし……。",
            "VoiceFileName": "1424010220",
            "CharacterMotions": [],
            "SpeakerIconId": "205"
        },
        {
            "Id": 142401024,
            "EpisodeMasterId": 142401,
            "Order": 1,
            "GroupOrder": 24,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "どうしようって、どうすればいいんだろうって、ずっとわからなくて……。/nせめて、パパとママを説得できればって……。",
            "VoiceFileName": "1424010230",
            "CharacterMotions": [],
            "SpeakerIconId": "205"
        },
        {
            "Id": 142401025,
            "EpisodeMasterId": 142401,
            "Order": 1,
            "GroupOrder": 25,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "ねえ、しぐれちゃん。/nそれなら、やっぱりレンさんに相談してみようよ。",
            "VoiceFileName": "1424010240",
            "CharacterMotions": [],
            "SpeakerIconId": "203"
        },
        {
