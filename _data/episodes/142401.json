            ],
            "SpeakerIconId": "204"
        },
        {
            "Id": 142401019,
            "EpisodeMasterId": 142401,
            "Order": 1,
            "GroupOrder": 19,
            "SpeakerName": "容",
            "FontSize": 2,
            "Phrase": "（それに……他人の事情だからそっとしておこう、とはならずに、/n　わざわざそこに踏み込んでまで、どうにかしようとしてくれるなんて……）",
            "VoiceFileName": "1424010180",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 71,
                    "BodyMotionMasterId": 7,
                    "SpineId": 20403,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "204"
        },
        {
            "Id": 142401020,
            "EpisodeMasterId": 142401,
            "Order": 1,
            "GroupOrder": 20,
            "SpeakerName": "容",
            "FontSize": 2,
            "Phrase": "（初魅の創り上げたEden……本当にいい仲間が集まってくれたよ。/n　こんなにも他者を思いやれて、思いきりぶつかってくれるんだから）",
            "VoiceFileName": "1424010190",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 103,
                    "BodyMotionMasterId": 15,
                    "SpineId": 20403,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
