            "EpisodeMasterId": 142401,
            "Order": 1,
            "GroupOrder": 22,
            "SpeakerName": "容",
            "FontSize": 2,
            "Phrase": "（もう少しだけ、ここで様子見といこうかな）",
            "VoiceFileName": "1424010210",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "BodyMotionMasterId": 13,
                    "SpineId": 20403,
                    "CharacterAppearanceType": 0,
