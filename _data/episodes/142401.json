            "EpisodeMasterId": 142401,
            "Order": 1,
            "GroupOrder": 26,
            "SpeakerName": "容",
            "FontSize": 2,
            "Phrase": "（しぐれ……自分の事情、ちゃんと話せたんだ。/n　その上でふたりは、しぐれの為になることを考えてくれてる……）",
            "VoiceFileName": "1424010250",
