                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "204"
        },
        {
            "Id": 142401009,
            "EpisodeMasterId": 142401,
            "Order": 1,
            "GroupOrder": 9,
            "SpeakerName": "大黒",
            "FontSize": 2,
            "Phrase": "ほ、本当は願い下げだけどっ……！/nでもっ、やっぱりそうされると気になんのよ！",
            "BgmFileName": "999",
            "VoiceFileName": "1424010080",
            "CharacterMotions": [],
            "SpeakerIconId": "202"
        },
        {
            "Id": 142401010,
            "EpisodeMasterId": 142401,
            "Order": 1,
            "GroupOrder": 10,
            "SpeakerName": "容",
            "FontSize": 2,
            "Phrase": "（！　……大黒……？）",
            "BgmFileName": "8",
            "VoiceFileName": "1424010090",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 511,
                    "BodyMotionMasterId": 5,
                    "SpineId": 20403,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "204"
        },
        {
            "Id": 142401011,
            "EpisodeMasterId": 142401,
            "Order": 1,
            "GroupOrder": 11,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "……だから、ほっといてくださいよ。/nこれ以上、大黒先輩が気にする必要なんてないじゃないですかぁ。",
            "VoiceFileName": "1424010100",
            "CharacterMotions": [],
            "SpeakerIconId": "205"
        },
        {
            "Id": 142401012,
            "EpisodeMasterId": 142401,
            "Order": 1,
            "GroupOrder": 12,
            "SpeakerName": "大黒",
            "FontSize": 2,
            "Phrase": "今まで一緒にEdenでやってきたんだから、気になるのは当然じゃない！/nそれに、なんでもずけずけ言うのがアンタの持ち味でしょ！？",
            "VoiceFileName": "1424010110",
            "CharacterMotions": [],
            "SpeakerIconId": "202"
        },
        {
            "Id": 142401013,
            "EpisodeMasterId": 142401,
            "Order": 1,
            "GroupOrder": 13,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "なんですかそれ……っ！！",
            "VoiceFileName": "1424010120",
            "CharacterMotions": [],
            "SpeakerIconId": "205"
        },
        {
            "Id": 142401014,
            "EpisodeMasterId": 142401,
            "Order": 1,
            "GroupOrder": 14,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "だーちゃんは、しぐれちゃんを心配してるから……。/nだから、こうして聞いてるんだよ。",
            "VoiceFileName": "1424010130",
            "CharacterMotions": [],
            "SpeakerIconId": "203"
        },
        {
            "Id": 142401015,
            "EpisodeMasterId": 142401,
            "Order": 1,
            "GroupOrder": 15,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "ほら、だーちゃんも！/nだーちゃんの気持ち、もっと分かりやすく言わないと伝わらないよっ！",
            "VoiceFileName": "1424010140",
            "CharacterMotions": [],
            "SpeakerIconId": "203"
        },
        {
            "Id": 142401016,
            "EpisodeMasterId": 142401,
            "Order": 1,
            "GroupOrder": 16,
            "SpeakerName": "大黒",
            "FontSize": 2,
            "Phrase": "うっ……悪かったわね……。",
            "VoiceFileName": "1424010150",
            "CharacterMotions": [],
            "SpeakerIconId": "202"
        },
        {
            "Id": 142401017,
            "EpisodeMasterId": 142401,
            "Order": 1,
            "GroupOrder": 17,
            "SpeakerName": "容",
            "FontSize": 2,
            "Phrase": "（大黒、仁花子……ふたりとも、しぐれのこと心配して……。/n　でもまさか、あの大黒のほうから歩み寄るなんてねぇ）",
            "VoiceFileName": "1424010160",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 103,
                    "BodyMotionMasterId": 7,
                    "SpineId": 20403,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "204"
        },
        {
            "Id": 142401018,
            "EpisodeMasterId": 142401,
            "Order": 1,
            "GroupOrder": 18,
            "SpeakerName": "容",
            "FontSize": 2,
            "Phrase": "（正直驚いたな……。/n　アタシの知らないうちに皆、成長していってるってわけだ）",
            "VoiceFileName": "1424010170",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "BodyMotionMasterId": 15,
                    "SpineId": 20403,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
