            "EpisodeMasterId": 142401,
            "Order": 1,
            "GroupOrder": 7,
            "SpeakerName": "容",
            "FontSize": 2,
            "Phrase": "（え？　今のは、大黒の声……！？/n　あんな大声出してたってことは、もしかして、しぐれとまた揉めて……？）",
            "BgmFileName": "404",
            "VoiceFileName": "1424010060",
            "CharacterMotions": [
