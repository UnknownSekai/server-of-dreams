            "EpisodeMasterId": 1020414,
            "Order": 1,
            "GroupOrder": 15,
            "SpeakerName": "大黒",
            "FontSize": 2,
            "Phrase": "（信じています、我が主…………！）",
            "VoiceFileName": "10204140140",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 103,
                    "BodyMotionMasterId": 4,
