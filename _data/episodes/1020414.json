        },
        {
            "Id": 1020414016,
            "EpisodeMasterId": 1020414,
            "Order": 1,
            "GroupOrder": 16,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "私はこの前、世界演劇リーグからの手紙には応じないと言ったな。/n……その考えは、今でも変わらない。",
            "VoiceFileName": "10204140150",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 74,
                    "BodyMotionMasterId": 3,
                    "LipSyncMasterId": 4,
                    "SpineId": 20103,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "201"
        },
        {
            "Id": 1020414017,
            "EpisodeMasterId": 1020414,
            "Order": 1,
            "GroupOrder": 17,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "……っ……！",
            "VoiceFileName": "10204140160",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "SpineId": 0,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 2,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                },
                {
                    "slotNumber": 2,
                    "FacialExpressionMasterId": 511,
                    "BodyMotionMasterId": 13,
                    "SpineId": 20503,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 4,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "205"
        },
        {
            "Id": 1020414018,
            "EpisodeMasterId": 1020414,
            "Order": 1,
            "GroupOrder": 18,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "だが……それはあくまで、世界演劇リーグが凝り固まった思考をした、/n権威の集まりだからというだけで、何も行動しないという意味ではない。",
            "VoiceFileName": "10204140170",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 107,
                    "BodyMotionMasterId": 21,
                    "LipSyncMasterId": 4,
                    "SpineId": 20103,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "201"
        },
        {
            "Id": 1020414019,
            "EpisodeMasterId": 1020414,
            "Order": 1,
            "GroupOrder": 19,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "いや違うな……少し前までの私は、劇団の名声や地位など不要だと、/n頑なに賞レースなどへの出場を拒んでいた。",
            "VoiceFileName": "10204140180",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 79,
                    "BodyMotionMasterId": 3,
                    "LipSyncMasterId": 4,
                    "SpineId": 20103,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "201"
        },
        {
            "Id": 1020414020,
            "EpisodeMasterId": 1020414,
            "Order": 1,
            "GroupOrder": 20,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "今でも、名声などという空虚なものは不要という思いに変わりはないが……/n人気が出なければ劇団の存続に関わるということも、また事実だ。",
            "VoiceFileName": "10204140190",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 107,
                    "LipSyncMasterId": 4,
                    "SpineId": 20103,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "201"
        },
        {
            "Id": 1020414021,
            "EpisodeMasterId": 1020414,
            "Order": 1,
            "GroupOrder": 21,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "だから少し趣向を変えて、/nEdenの実力を、世界に知らしめてやるのもいいと思ってな。",
            "BgmFileName": "999",
            "VoiceFileName": "10204140200",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 103,
                    "BodyMotionMasterId": 15,
                    "LipSyncMasterId": 1,
                    "SpineId": 20103,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "201"
        },
        {
            "Id": 1020414022,
            "EpisodeMasterId": 1020414,
            "Order": 1,
            "GroupOrder": 22,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "そこで、だ……我がEdenは次回の公演で、/nドイツの『プロメテウス賞』を狙うことにした！",
            "BackgroundCharacterImageFileName": "142390_0",
            "BgmFileName": "401",
            "VoiceFileName": "10204140210",
            "CharacterMotions": [],
            "SpeakerIconId": "201"
        },
        {
            "Id": 1020414023,
            "EpisodeMasterId": 1020414,
            "Order": 1,
            "GroupOrder": 23,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "（！　プロメテウス賞……！）",
            "BackgroundCharacterImageFileName": "142390_0",
            "VoiceFileName": "10204140220",
            "CharacterMotions": [],
            "SpeakerIconId": "205"
        },
        {
            "Id": 1020414024,
            "EpisodeMasterId": 1020414,
            "Order": 1,
            "GroupOrder": 24,
            "SpeakerName": "容",
            "FontSize": 2,
            "Phrase": "なるほど、そうきたか。/nプロメテウス賞を狙うって……本気で言ってるのかい、初魅？",
            "BackgroundCharacterImageFileName": "142390_0",
            "VoiceFileName": "10204140230",
            "CharacterMotions": [],
            "SpeakerIconId": "204"
        },
        {
            "Id": 1020414025,
            "EpisodeMasterId": 1020414,
            "Order": 1,
            "GroupOrder": 25,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "フッ、私がわざわざ冗談を言うために、/nこのように皆を集めたと思うか？",
            "BackgroundCharacterImageFileName": "142390_0",
            "VoiceFileName": "10204140240",
            "CharacterMotions": [],
            "SpeakerIconId": "201"
        },
        {
            "Id": 1020414026,
            "EpisodeMasterId": 1020414,
            "Order": 1,
            "GroupOrder": 26,
            "SpeakerName": "容",
            "FontSize": 2,
            "Phrase": "いや、まぁそれはそうなんだけど……でもプロメテウス賞っていうと、/n他の賞と比べても、一筋縄じゃいかない賞じゃない？",
            "BackgroundCharacterImageFileName": "142390_0",
            "VoiceFileName": "10204140250",
            "CharacterMotions": [],
            "SpeakerIconId": "204"
        },
        {
            "Id": 1020414027,
            "EpisodeMasterId": 1020414,
            "Order": 1,
            "GroupOrder": 27,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "そうなんですか、いるるん？　話題にはなってますよね！",
            "BackgroundCharacterImageFileName": "142390_0",
            "VoiceFileName": "10204140260",
            "CharacterMotions": [],
            "SpeakerIconId": "203"
        },
        {
            "Id": 1020414028,
            "EpisodeMasterId": 1020414,
            "Order": 1,
            "GroupOrder": 28,
            "SpeakerName": "容",
            "FontSize": 2,
            "Phrase": "ああ……プロメテウス賞というのは、欧州の演劇賞のひとつなんだけど、/n審査基準は近年では珍しく、芸術性や独創性を重視しているんだよ。",
            "BackgroundCharacterImageFileName": "142390_0",
            "VoiceFileName": "10204140270",
            "CharacterMotions": [],
            "SpeakerIconId": "204"
        },
        {
            "Id": 1020414029,
            "EpisodeMasterId": 1020414,
            "Order": 1,
            "GroupOrder": 29,
            "SpeakerName": "容",
            "FontSize": 2,
            "Phrase": "劇団の知名度や人気、センスでは勝負できない……。/nまさに、舞台の総合芸術としての力が求められるってわけ。",
            "BackgroundCharacterImageFileName": "142390_0",
            "VoiceFileName": "10204140280",
            "CharacterMotions": [],
            "SpeakerIconId": "204"
        },
        {
            "Id": 1020414030,
            "EpisodeMasterId": 1020414,
            "Order": 1,
            "GroupOrder": 30,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "そう、センスを重要視する世界演劇リーグとは違い、/n古き良き演劇の良さを評価する、素晴らしい賞だ！",
            "BackgroundCharacterImageFileName": "142390_0",
            "VoiceFileName": "10204140290",
            "CharacterMotions": [],
            "SpeakerIconId": "201"
        },
        {
            "Id": 1020414031,
            "EpisodeMasterId": 1020414,
            "Order": 1,
            "GroupOrder": 31,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "賞レースの類など、てんで興味はないが、/nこの賞だけは注目に値すると私は思っている。",
            "BackgroundCharacterImageFileName": "142390_0",
            "VoiceFileName": "10204140300",
            "CharacterMotions": [],
            "SpeakerIconId": "201"
        },
        {
            "Id": 1020414032,
            "EpisodeMasterId": 1020414,
            "Order": 1,
            "GroupOrder": 32,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "人気だけの劇団は実力を測られるのが怖くて応募すらしない。/nどうだ、Edenの実力、ぶつけてみたいと思わないか？",
            "BackgroundCharacterImageFileName": "142390_0",
            "VoiceFileName": "10204140310",
            "CharacterMotions": [],
            "SpeakerIconId": "201"
        },
        {
            "Id": 1020414033,
            "EpisodeMasterId": 1020414,
            "Order": 1,
            "GroupOrder": 33,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "すっごくいいと思います！　プロメテウス賞……！",
            "VoiceFileName": "10204140320",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 200,
                    "BodyMotionMasterId": 2,
                    "LipSyncMasterId": 2,
                    "SpineId": 20303,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "203"
        },
        {
            "Id": 1020414034,
            "EpisodeMasterId": 1020414,
            "Order": 1,
            "GroupOrder": 34,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "（この賞を獲れたら、きっとしぐれちゃんのご両親だって……！）",
            "VoiceFileName": "10204140330",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 101,
                    "BodyMotionMasterId": 13,
                    "SpineId": 0,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "203"
        },
        {
            "Id": 1020414035,
            "EpisodeMasterId": 1020414,
            "Order": 1,
            "GroupOrder": 35,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "（本当に大丈夫なのかな……。/n　だってもし『プロメテウス賞』を受賞できなかったら……？）",
            "VoiceFileName": "10204140340",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 400,
                    "BodyMotionMasterId": 11,
                    "SpineId": 20503,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "205"
        },
        {
