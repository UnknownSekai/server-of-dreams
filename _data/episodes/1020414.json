            "EpisodeMasterId": 1020414,
            "Order": 1,
            "GroupOrder": 36,
            "SpeakerName": "Eden劇団員",
            "FontSize": 2,
            "Phrase": "完全な実力勝負かぁ……確かにEdenらしいけど、でも……。",
            "VoiceFileName": "10204140350",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020414037,
