    "Next": 142462,
    "Chapter": "妻たちのもとへ墜ちていく",
    "Title": "悪役への反響",
    "EpisodeDetail": [
        {
            "Id": 142461001,
            "EpisodeMasterId": 142461,
            "Order": 1,
            "GroupOrder": 1,
            "SpeakerName": "仁花子の友人１",
            "FontSize": 2,
            "Phrase": "ねえねえ舎人さん！　この間の『青髪公の帰らぬ妻』の舞台、観たよー！/n舎人さん、主役？　だったよね！",
            "BackgroundImageFileName": "30",
            "BgmFileName": "402",
            "VoiceFileName": "1424610010",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142461002,
            "EpisodeMasterId": 142461,
            "Order": 1,
            "GroupOrder": 2,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "えっ、観に来てくれたんだ！　ありがとう！！/n一応、ダブル主演ではあるんだけどね……えへへ……。",
            "VoiceFileName": "1424610020",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 200,
                    "BodyMotionMasterId": 20,
                    "LipSyncMasterId": 1,
                    "SpineId": 20302,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "203"
        },
        {
            "Id": 142461003,
            "EpisodeMasterId": 142461,
            "Order": 1,
            "GroupOrder": 3,
            "SpeakerName": "仁花子の友人２",
            "FontSize": 2,
            "Phrase": "なんかこう、怖い感じの演技とか～……すっごい良かった！/n劇団Edenのダークな雰囲気の舞台、私好きなんだ～。",
            "VoiceFileName": "1424610030",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142461004,
            "EpisodeMasterId": 142461,
            "Order": 1,
            "GroupOrder": 4,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "本当？　それを聞いたら、劇団のみんなも喜ぶと思う！/n特に、脚本とか演出の全部を担当してる、レンさんなんかは！",
            "VoiceFileName": "1424610040",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 101,
                    "BodyMotionMasterId": 13,
                    "LipSyncMasterId": 2,
                    "SpineId": 20302,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "203"
        },
        {
            "Id": 142461005,
            "EpisodeMasterId": 142461,
            "Order": 1,
            "GroupOrder": 5,
            "SpeakerName": "仁花子の友人２",
            "FontSize": 2,
            "Phrase": "それってもしかして連尺野初魅さんのこと？/nあの人、カッコいいよね～！！",
            "VoiceFileName": "1424610050",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142461006,
            "EpisodeMasterId": 142461,
            "Order": 1,
            "GroupOrder": 6,
            "SpeakerName": "仁花子の友人２",
            "FontSize": 2,
            "Phrase": "この間の舞台の時も、/n舎人さんと向かい合うシーンとか、つい見とれちゃった……！",
            "VoiceFileName": "1424610060",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142461007,
            "EpisodeMasterId": 142461,
            "Order": 1,
            "GroupOrder": 7,
            "SpeakerName": "仁花子の友人１",
            "FontSize": 2,
            "Phrase": "でも、あの時の舎人さんも良かったよね！/nなんだろう……普段じゃ絶対に見れない表情が見れたっていうか！",
            "VoiceFileName": "1424610070",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142461008,
            "EpisodeMasterId": 142461,
            "Order": 1,
            "GroupOrder": 8,
            "SpeakerName": "仁花子の友人２",
            "FontSize": 2,
            "Phrase": "たしかに！　あんな舎人さん、新鮮だよね～！/nサイコパスみたいな？　そういう悪役！",
            "VoiceFileName": "1424610080",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142461009,
            "EpisodeMasterId": 142461,
            "Order": 1,
            "GroupOrder": 9,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "そ、そうかな……？/n役によっては、そういう役柄を演じることもあるよ？",
            "VoiceFileName": "1424610090",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 103,
                    "BodyMotionMasterId": 11,
                    "LipSyncMasterId": 1,
                    "SpineId": 20302,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "203"
        },
        {
            "Id": 142461010,
            "EpisodeMasterId": 142461,
            "Order": 1,
            "GroupOrder": 10,
            "SpeakerName": "仁花子の友人２",
            "FontSize": 2,
            "Phrase": "えー、舎人さんが悪役なんて、今まで全っ然想像つかなかったよ～！",
            "VoiceFileName": "1424610100",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142461011,
            "EpisodeMasterId": 142461,
            "Order": 1,
            "GroupOrder": 11,
            "SpeakerName": "仁花子の友人１",
            "FontSize": 2,
            "Phrase": "うんうん。イメージないよね～。/n今だってこうやって話してると、普通の女子高生なわけだし！",
            "VoiceFileName": "1424610110",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142461012,
            "EpisodeMasterId": 142461,
            "Order": 1,
            "GroupOrder": 12,
            "SpeakerName": "仁花子の友人１",
            "FontSize": 2,
            "Phrase": "悪役やってる舎人さんって珍しいよ！",
            "VoiceFileName": "1424610120",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142461013,
            "EpisodeMasterId": 142461,
            "Order": 1,
            "GroupOrder": 13,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "あはは……そう、なのかな？/n自分じゃよく分かんないや……。",
            "VoiceFileName": "1424610130",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 202,
                    "BodyMotionMasterId": 20,
                    "LipSyncMasterId": 1,
                    "SpineId": 20302,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "203"
        },
        {
            "Id": 142461014,
            "EpisodeMasterId": 142461,
            "Order": 1,
            "GroupOrder": 14,
            "SpeakerName": "仁花子の友人２",
            "FontSize": 2,
            "Phrase": "役作りとか大変だったんじゃない？/nいつもそうかもしれないけど……ほら、悪役なんていつもと全然違うんだし！",
            "VoiceFileName": "1424610140",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142461015,
            "EpisodeMasterId": 142461,
            "Order": 1,
            "GroupOrder": 15,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "うーん……他の役作りより苦労したとかは、別にないかなぁ。/n必死に練習してたら、いつの間にか役には入り込めてたんだっ。",
            "VoiceFileName": "1424610150",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 102,
                    "BodyMotionMasterId": 7,
                    "LipSyncMasterId": 4,
                    "SpineId": 20302,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "203"
        },
        {
            "Id": 142461016,
            "EpisodeMasterId": 142461,
            "Order": 1,
            "GroupOrder": 16,
            "SpeakerName": "仁花子の友人１",
            "FontSize": 2,
            "Phrase": "えー！　意外！/nあんな役、絶対苦労しそうなのに！",
            "VoiceFileName": "1424610160",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142461017,
            "EpisodeMasterId": 142461,
            "Order": 1,
            "GroupOrder": 17,
            "SpeakerName": "仁花子の友人２",
            "FontSize": 2,
            "Phrase": "ね！　舎人さんの中じゃ、考えられない～みたいな役かと思ってた！",
            "VoiceFileName": "1424610170",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142461018,
            "EpisodeMasterId": 142461,
            "Order": 1,
            "GroupOrder": 18,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "まぁ、誰かに酷いことするのは良くないと思うけどね……。/nでも、青髪公には、青髪公なりの愛情があったわけだし……。",
            "VoiceFileName": "1424610180",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 102,
                    "BodyMotionMasterId": 11,
                    "LipSyncMasterId": 4,
                    "SpineId": 20302,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "203"
        },
        {
            "Id": 142461019,
            "EpisodeMasterId": 142461,
            "Order": 1,
            "GroupOrder": 19,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "そういうのも含めて、新鮮で楽しかったよ？/n青髪公の役を演じるの！",
            "VoiceFileName": "1424610190",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 103,
                    "BodyMotionMasterId": 20,
                    "LipSyncMasterId": 1,
                    "SpineId": 20302,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "203"
        },
        {
            "Id": 142461020,
            "EpisodeMasterId": 142461,
            "Order": 1,
            "GroupOrder": 20,
            "SpeakerName": "仁花子の友人１・２",
            "FontSize": 2,
            "Phrase": "さっすが～！",
            "VoiceFileName": "1424610200",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142461021,
            "EpisodeMasterId": 142461,
            "Order": 1,
            "GroupOrder": 21,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "え……！？",
            "VoiceFileName": "1424610210",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 102,
                    "BodyMotionMasterId": 11,
                    "LipSyncMasterId": 4,
                    "SpineId": 20302,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "203"
        },
        {
            "Id": 142461022,
            "EpisodeMasterId": 142461,
            "Order": 1,
            "GroupOrder": 22,
            "SpeakerName": "仁花子の友人１",
            "FontSize": 2,
            "Phrase": "やっぱりプロの役者さんだよね、舎人さんって！",
            "VoiceFileName": "1424610220",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142461023,
            "EpisodeMasterId": 142461,
            "Order": 1,
            "GroupOrder": 23,
            "SpeakerName": "仁花子の友人２",
            "FontSize": 2,
            "Phrase": "ほんとほんと！/n同じ年でクラスメイトなのに、全然違う世界で頑張ってて……尊敬しちゃう！",
            "VoiceFileName": "1424610230",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142461024,
            "EpisodeMasterId": 142461,
            "Order": 1,
            "GroupOrder": 24,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "そんなそんな……！　ほ、褒めすぎだよ～！/nみんなだって、それぞれ部活とか、アルバイトとか頑張ってるし！",
            "VoiceFileName": "1424610240",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 114,
                    "BodyMotionMasterId": 12,
                    "LipSyncMasterId": 1,
                    "SpineId": 20302,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "203"
        },
        {
            "Id": 142461025,
            "EpisodeMasterId": 142461,
            "Order": 1,
            "GroupOrder": 25,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "それぞれ違う場所で頑張ってる同士でしょ？/n私が特別なわけじゃないから……！",
            "VoiceFileName": "1424610250",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 103,
                    "BodyMotionMasterId": 20,
                    "LipSyncMasterId": 1,
                    "SpineId": 20302,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "203"
        },
        {
            "Id": 142461026,
            "EpisodeMasterId": 142461,
            "Order": 1,
            "GroupOrder": 26,
            "SpeakerName": "仁花子の友人１",
            "FontSize": 2,
            "Phrase": "そういう謙虚なところが、ますます好感度高いよね～、舎人さんは！",
            "VoiceFileName": "1424610260",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142461027,
            "EpisodeMasterId": 142461,
            "Order": 1,
            "GroupOrder": 27,
            "SpeakerName": "仁花子の友人２",
            "FontSize": 2,
            "Phrase": "言えてる！　……これからも舎人さんのこと推しまくって、/n超応援してるから、演劇、頑張ってね！",
            "VoiceFileName": "1424610270",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142461028,
            "EpisodeMasterId": 142461,
            "Order": 1,
            "GroupOrder": 28,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "ふたりとも……ありがとう！！/n私、これからも沢山頑張るねっ！！",
            "VoiceFileName": "1424610280",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 101,
                    "BodyMotionMasterId": 8,
                    "LipSyncMasterId": 2,
                    "SpineId": 20302,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "203"
        },
        {
            "Id": 142461029,
            "EpisodeMasterId": 142461,
            "Order": 1,
            "GroupOrder": 29,
            "SpeakerName": "仁花子の友人１",
            "FontSize": 2,
            "Phrase": "うん、期待してる！",
            "VoiceFileName": "1424610290",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142461030,
            "EpisodeMasterId": 142461,
            "Order": 1,
            "GroupOrder": 30,
            "SpeakerName": "仁花子の友人２",
            "FontSize": 2,
            "Phrase": "それじゃあ私たちはお先に帰るねー。/nまた明日ね、舎人さん。",
            "VoiceFileName": "1424610300",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
