        },
        {
            "Id": 142411002,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 2,
            "SpeakerName": "教会の関係者",
            "FontSize": 2,
            "Phrase": "ああ、八恵ちゃん！　こんにちは。/n今日は水泳教室の手伝いに来てくれて、ありがとう。",
            "VoiceFileName": "1424110020",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142411003,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 3,
            "SpeakerName": "教会の関係者",
            "FontSize": 2,
            "Phrase": "けど……お休みの日に頼んじゃって、大丈夫だった？/n舞台のお稽古だって、忙しいんでしょう？",
            "VoiceFileName": "1424110030",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142411004,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 4,
            "SpeakerName": "八恵",
            "FontSize": 2,
            "Phrase": "いえ、お気になさらないでください。",
            "VoiceFileName": "1424110040",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 100,
                    "BodyMotionMasterId": 12,
                    "LipSyncMasterId": 1,
                    "SpineId": 10417,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "104"
        },
        {
            "Id": 142411005,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 5,
            "SpeakerName": "八恵",
            "FontSize": 2,
            "Phrase": "特に予定もなかったですし、/n何より、皆さんのお役に立てるのなら、私も嬉しいですから♪",
            "VoiceFileName": "1424110050",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 200,
                    "BodyMotionMasterId": 11,
                    "LipSyncMasterId": 1,
                    "SpineId": 0,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "104"
        },
        {
            "Id": 142411006,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 6,
            "SpeakerName": "教会の関係者",
            "FontSize": 2,
            "Phrase": "本当？　そう言ってくれると助かるわ。/nいつもありがとね。",
            "VoiceFileName": "1424110060",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142411007,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 7,
            "SpeakerName": "教会の関係者",
            "FontSize": 2,
            "Phrase": "もし困ったことがあったら、なんでも言ってちょうだい。/nそれじゃあ、後はよろしくお願いね。",
            "VoiceFileName": "1424110070",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142411008,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 8,
            "SpeakerName": "八恵",
            "FontSize": 2,
            "Phrase": "はいっ！　お任せくださいっ！",
            "VoiceFileName": "1424110080",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 101,
                    "BodyMotionMasterId": 20,
                    "LipSyncMasterId": 2,
                    "SpineId": 10417,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "104"
        },
        {
            "Id": 142411009,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 9,
            "SpeakerName": "八恵",
            "FontSize": 2,
            "Phrase": "新妻八恵と申します。/n皆さん、今日はよろしくお願いします。",
            "VoiceFileName": "1424110090",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 100,
                    "BodyMotionMasterId": 13,
                    "LipSyncMasterId": 1,
                    "SpineId": 0,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "104"
        },
        {
            "Id": 142411010,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 10,
            "SpeakerName": "女の子１",
            "FontSize": 2,
            "Phrase": "あ、おねえちゃん見たことあるー！　『だいすたー』の人でしょ？/nねえねえ、お芝居じょうずなの？　わたしも見てみたいなっ！",
            "VoiceFileName": "1424110100",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142411011,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 11,
            "SpeakerName": "八恵",
            "FontSize": 2,
            "Phrase": "えっ？　ええっと、それは……また今度、でしょうか？",
            "VoiceFileName": "1424110110",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 201,
                    "BodyMotionMasterId": 6,
                    "LipSyncMasterId": 1,
                    "SpineId": 10417,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "104"
        },
        {
            "Id": 142411012,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 12,
            "SpeakerName": "女の子２",
            "FontSize": 2,
            "Phrase": "わあ……！　おねえちゃんの水着、とってもかわいい～！",
            "VoiceFileName": "1424110120",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142411013,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 13,
            "SpeakerName": "八恵",
            "FontSize": 2,
            "Phrase": "ふふ、ありがとうございます♪/nこれは、私のお気に入りの水着なんです。",
            "VoiceFileName": "1424110130",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 202,
                    "BodyMotionMasterId": 11,
                    "LipSyncMasterId": 1,
                    "SpineId": 10417,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "104"
        },
        {
            "Id": 142411014,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 14,
            "SpeakerName": "女の子2",
            "FontSize": 2,
            "Phrase": "ねーねー、おねーちゃんって、泳ぐのうまいー？/nわたし、平泳ぎがとくいなんだよー！",
            "VoiceFileName": "1424110140",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142411015,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 15,
            "SpeakerName": "八恵",
            "FontSize": 2,
            "Phrase": "私は……人並みには、といったところでしょうか。/n良ければ後で平泳ぎを泳ぐところ、私にも見せてください♪",
            "VoiceFileName": "1424110150",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 102,
                    "BodyMotionMasterId": 7,
                    "LipSyncMasterId": 1,
                    "SpineId": 10417,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "104"
        },
        {
            "Id": 142411016,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 16,
            "SpeakerName": "女の子2",
            "FontSize": 2,
            "Phrase": "うんっ！　もちろん！",
            "VoiceFileName": "1424110160",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142411017,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 17,
            "SpeakerName": "教会の関係者",
            "FontSize": 2,
            "Phrase": "あらあら、もうみんなと打ち解けたのね。/nさすがは八恵ちゃんだわ。",
            "VoiceFileName": "1424110170",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142411018,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 18,
            "SpeakerName": "八恵",
            "FontSize": 2,
            "Phrase": "いえ、私は全然……。/nそれにさっきまで、この子たちの元気さに圧倒されちゃっていましたから。",
            "VoiceFileName": "1424110180",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 103,
                    "BodyMotionMasterId": 6,
                    "LipSyncMasterId": 1,
                    "SpineId": 10417,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "104"
        },
        {
            "Id": 142411019,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 19,
            "SpeakerName": "八恵",
            "FontSize": 2,
            "Phrase": "ですが……皆さんとっても明るく優しいので、/nお陰で私も、自然と輪に入ることができたんです。",
            "VoiceFileName": "1424110190",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 200,
                    "BodyMotionMasterId": 14,
                    "LipSyncMasterId": 1,
                    "SpineId": 10417,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "104"
        },
        {
            "Id": 142411020,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 20,
            "SpeakerName": "教会の関係者",
            "FontSize": 2,
            "Phrase": "そう……でもそれなら安心したわ。",
            "VoiceFileName": "1424110200",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142411021,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 21,
            "SpeakerName": "教会の関係者",
            "FontSize": 2,
            "Phrase": "この子たちってば、本当に元気いっぱいだから、/n八恵ちゃんの負担になるんじゃないかと心配してたんだけど……。",
            "VoiceFileName": "1424110210",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142411022,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 22,
            "SpeakerName": "教会の関係者",
            "FontSize": 2,
            "Phrase": "取り越し苦労だったみたいね。",
            "VoiceFileName": "1424110220",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142411023,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 23,
            "SpeakerName": "八恵",
            "FontSize": 2,
            "Phrase": "はい、私なら大丈夫ですよ。/nでも、心配してくださりありがとうございます♪",
            "VoiceFileName": "1424110230",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 103,
                    "BodyMotionMasterId": 13,
                    "LipSyncMasterId": 1,
                    "SpineId": 10417,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "104"
        },
        {
            "Id": 142411024,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 24,
            "SpeakerName": "女の子１",
            "FontSize": 2,
            "Phrase": "ねーおねえちゃん！　いつまでお話ししてるのー？/nおねえちゃんも、わたしたちと一緒に泳ごー！",
            "VoiceFileName": "1424110240",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142411025,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 25,
            "SpeakerName": "女の子２",
            "FontSize": 2,
            "Phrase": "そーだ、おねーちゃん！",
            "VoiceFileName": "1424110250",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142411026,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 26,
            "SpeakerName": "女の子２",
            "FontSize": 2,
            "Phrase": "おねーちゃんに、あとでわたしの平泳ぎ見せてあげるから、/nおねーちゃんの泳いでるとこも見てみたい！　ねー、見せてよ！",
            "VoiceFileName": "1424110260",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142411027,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 27,
            "SpeakerName": "八恵",
            "FontSize": 2,
            "Phrase": "え？　私が泳いでるところ、ですか？",
            "VoiceFileName": "1424110270",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 500,
                    "BodyMotionMasterId": 5,
                    "LipSyncMasterId": 1,
                    "SpineId": 10417,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "104"
        },
        {
            "Id": 142411028,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 28,
            "SpeakerName": "女の子１",
            "FontSize": 2,
            "Phrase": "あ、わたしも見たい！",
            "VoiceFileName": "1424110280",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142411029,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 29,
            "SpeakerName": "女の子２",
            "FontSize": 2,
            "Phrase": "わたしもー！",
            "VoiceFileName": "1424110290",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142411030,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 30,
            "SpeakerName": "子どもたち",
            "FontSize": 2,
            "Phrase": "ねー、おねーちゃん、おねがーい！",
            "VoiceFileName": "1424110300",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142411031,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 31,
            "SpeakerName": "八恵",
            "FontSize": 2,
            "Phrase": "ふふっ、わかりました。/n私の泳ぐところ、皆さんにお見せしますね♪",
            "VoiceFileName": "1424110310",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 200,
                    "BodyMotionMasterId": 11,
                    "LipSyncMasterId": 1,
                    "SpineId": 10417,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "104"
        },
        {
            "Id": 142411032,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 32,
            "SpeakerName": "子どもたち",
            "FontSize": 2,
            "Phrase": "わーい！　やったー！",
            "VoiceFileName": "1424110320",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142411033,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 33,
            "SpeakerName": "女の子１",
            "FontSize": 2,
            "Phrase": "ありがとう、おねえちゃん！",
            "VoiceFileName": "1424110330",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142411034,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 34,
            "SpeakerName": "女の子２",
            "FontSize": 2,
            "Phrase": "おねえちゃんが泳ぐところ見るの、とっても楽しみ！",
            "VoiceFileName": "1424110340",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142411035,
            "EpisodeMasterId": 142411,
            "Order": 1,
            "GroupOrder": 35,
            "SpeakerName": "八恵",
            "FontSize": 2,
            "Phrase": "（皆さん、こんなに楽しみにしてくださっています……。/n　これは精一杯、期待に応えられるよう頑張らないと、ですねっ！）",
