            "EpisodeMasterId": 142442,
            "Order": 1,
            "GroupOrder": 11,
            "SpeakerName": "スタッフ２",
            "FontSize": 2,
            "Phrase": "はーい！　では王さん、次こっちに目線くださーい！",
            "BackgroundCharacterImageFileName": "142440_0",
            "VoiceFileName": "1424420080",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
