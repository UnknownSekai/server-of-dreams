            "EpisodeMasterId": 142442,
            "Order": 1,
            "GroupOrder": 10,
            "SpeakerName": "プロデューサー",
            "FontSize": 2,
            "Phrase": "これは素晴らしい……！　キミ、想像してた以上だよ！/nさぁ、早速撮影を始めよう！！　こりゃあ、いい画が撮れそうだ！",
            "VoiceFileName": "1424420070",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
