            "SpeakerIconId": "204"
        },
        {
            "Id": 142462007,
            "EpisodeMasterId": 142462,
            "Order": 1,
            "GroupOrder": 7,
            "SpeakerName": "容",
            "FontSize": 2,
            "Phrase": "青髪公はただの悪役ってわけでもない……、/n独善的な愛情ゆえに、妻たちを死に至らしめ、最後は自らも死に至る……。",
