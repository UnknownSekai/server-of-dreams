            "EpisodeMasterId": 142462,
            "Order": 1,
            "GroupOrder": 10,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "ほ、本当……！？　一応評判は良かったから、/n悪くはなかったのかな～とは思ってたんですけど……。",
            "VoiceFileName": "1424620100",
            "CharacterMotions": [
