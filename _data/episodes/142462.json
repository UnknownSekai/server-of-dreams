            "SpeakerIconId": "204"
        },
        {
            "Id": 142462009,
            "EpisodeMasterId": 142462,
            "Order": 1,
            "GroupOrder": 9,
            "SpeakerName": "容",
            "FontSize": 2,
            "Phrase": "アタシは前妻の霊役として、青髪公と新妻であるしぐれの前にも立ったけど、/n仁花子の出で立ちは、想像した青髪公そのものだった。",
