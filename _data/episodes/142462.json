            "EpisodeMasterId": 142462,
            "Order": 1,
            "GroupOrder": 19,
            "SpeakerName": "容",
            "FontSize": 2,
            "Phrase": "あれは及第点どころか、百点満点の大正解だったと思うよ。/n仁花子の青髪公は。……悪役なのに、ちゃんと格好良さもあったしさ。",
            "VoiceFileName": "1424620190",
            "CharacterMotions": [
