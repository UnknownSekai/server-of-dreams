            "EpisodeMasterId": 142462,
            "Order": 1,
            "GroupOrder": 22,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "確かに、今まであまりやってこなかった役柄だったけど……。",
