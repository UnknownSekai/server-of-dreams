            "EpisodeMasterId": 142462,
            "Order": 1,
            "GroupOrder": 24,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "それに稽古の時だって、普段やらない役だからこそ、/n新鮮で楽しくて、すっかりのめり込んじゃいましたし！",
            "VoiceFileName": "1424620240",
            "CharacterMotions": [
