            "EpisodeMasterId": 142462,
            "Order": 1,
            "GroupOrder": 18,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "ですねー……。/n稽古中は役作りに必死だったけど、ちゃんと青髪公になれてたんだ、私……。",
