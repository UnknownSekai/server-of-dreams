            "EpisodeMasterId": 142462,
            "Order": 1,
            "GroupOrder": 20,
            "SpeakerName": "容",
            "FontSize": 2,
            "Phrase": "ほんと驚いたよ。/n仁花子にもああいう役が演じられるんだねぇ。",
