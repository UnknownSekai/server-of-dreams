            "EpisodeMasterId": 142462,
            "Order": 1,
            "GroupOrder": 26,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "心配してくれるのは、すごい嬉しいですけど……、/n「え？　私は全然平気だよ」って思えちゃうんです。",
