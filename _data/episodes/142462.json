            "EpisodeMasterId": 142462,
            "Order": 1,
            "GroupOrder": 21,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "んー……クラスの子たちにも、同じこと言われました。/n「舎人さんが悪役を演じるなんて、珍しい」って……。",
            "VoiceFileName": "1424620210",
