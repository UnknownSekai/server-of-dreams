            "EpisodeMasterId": 142462,
            "Order": 1,
            "GroupOrder": 23,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "他の役を演じる時と同じように、一生懸命、必死に稽古してたら、/nいつの間にか演じることが出来てた……って感じなんです。",
            "VoiceFileName": "1424620230",
            "CharacterMotions": [
