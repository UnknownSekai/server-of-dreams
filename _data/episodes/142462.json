            "EpisodeMasterId": 142462,
            "Order": 1,
            "GroupOrder": 25,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "だから、みんなから「大変だったでしょ？」って聞かれると……、/nあんまりしっくり来ないと言いますか……。",
            "VoiceFileName": "1424620250",
            "CharacterMotions": [
