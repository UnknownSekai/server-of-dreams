            "EpisodeMasterId": 142462,
            "Order": 1,
            "GroupOrder": 8,
            "SpeakerName": "容",
            "FontSize": 2,
            "Phrase": "なんとなく理解はできても、/nそれを演技として自分の中に落とし込むというのは、素直に凄いと思う。",
            "VoiceFileName": "1424620080",
            "CharacterMotions": [
