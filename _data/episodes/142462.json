            "EpisodeMasterId": 142462,
            "Order": 1,
            "GroupOrder": 11,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "やっぱり、同じ舞台に立つ演者から言われると、また違いますね。/n説得力もあって……すごく自信になります！",
            "VoiceFileName": "1424620110",
