        {
            "Id": 2007106018,
            "EpisodeMasterId": 2007106,
            "Order": 1,
            "GroupOrder": 18,
            "SpeakerName": "ここな",
            "FontSize": 2,
            "Phrase": "ダイスターの祭典に、ひとりで立つんだもん。/n不安になるのは当然だよ。",
            "BackgroundCharacterImageFileName": "142470_0",
            "VoiceFileName": "20071060180",
            "CharacterMotions": [],
            "SpeakerIconId": "101"
        },
        {
            "Id": 2007106019,
            "EpisodeMasterId": 2007106,
            "Order": 1,
            "GroupOrder": 19,
            "SpeakerName": "静香",
            "FontSize": 2,
            "Phrase": "そうね、それに別劇団の役者と舞台を演じないといけない。/n……そのプレッシャーは、私たちには計り知れないわ。",
            "BackgroundCharacterImageFileName": "142470_0",
            "VoiceFileName": "20071060190",
            "CharacterMotions": [],
            "SpeakerIconId": "102"
        },
        {
            "Id": 2007106020,
            "EpisodeMasterId": 2007106,
            "Order": 1,
            "GroupOrder": 20,
            "SpeakerName": "ここな",
            "FontSize": 2,
            "Phrase": "でもね、同じ舞台に立つことは出来ないかもしれないけど……、/nそれでも八恵ちゃんの支えになれるように頑張るから！",
            "BackgroundCharacterImageFileName": "142470_0",
            "VoiceFileName": "20071060200",
            "CharacterMotions": [],
            "SpeakerIconId": "101"
        },
        {
            "Id": 2007106021,
            "EpisodeMasterId": 2007106,
            "Order": 1,
            "GroupOrder": 21,
            "SpeakerName": "静香",
            "FontSize": 2,
            "Phrase": "ずっと応援してる。それに、私たちも八恵ちゃんと同じく、/n劇団での舞台で良い物を届けてみせる。",
            "BackgroundCharacterImageFileName": "142470_0",
            "VoiceFileName": "20071060210",
            "CharacterMotions": [],
            "SpeakerIconId": "102"
        },
        {
            "Id": 2007106022,
            "EpisodeMasterId": 2007106,
            "Order": 1,
            "GroupOrder": 22,
            "SpeakerName": "静香",
            "FontSize": 2,
            "Phrase": "だから、ひとりじゃないわ。/n八恵ちゃん。",
            "BackgroundCharacterImageFileName": "142470_0",
            "VoiceFileName": "20071060220",
            "CharacterMotions": [],
            "SpeakerIconId": "102"
        },
        {
            "Id": 2007106023,
            "EpisodeMasterId": 2007106,
            "Order": 1,
            "GroupOrder": 23,
            "SpeakerName": "八恵",
            "FontSize": 2,
            "Phrase": "ここなさん、静香さん……！",
