            "EpisodeMasterId": 2007106,
            "Order": 1,
            "GroupOrder": 13,
            "SpeakerName": "八恵",
            "FontSize": 2,
            "Phrase": "（ダイスターの祭典に立つということは、柊さんと同じ景色を見ること。/n　そして、柊さんの夢を背負うこと……だと思うんです）",
            "VoiceFileName": "20071060130",
            "CharacterMotions": [
