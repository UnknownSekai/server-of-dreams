            "GroupOrder": 12,
            "SpeakerName": "八恵",
            "FontSize": 2,
            "Phrase": "（柊さんはワールドダイスターをシリウスから出すまで、/n　戻るつもりはないと言ってました）",
            "VoiceFileName": "20071060120",
            "CharacterMotions": [
