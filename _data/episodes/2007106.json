            "EpisodeMasterId": 2007106,
            "Order": 1,
            "GroupOrder": 14,
            "SpeakerName": "八恵",
            "FontSize": 2,
            "Phrase": "（私は……舞台を壊しかけたことがあります。/n　今だって、シリウスや色々な人の助けがあって舞台に立っている……）",
            "VoiceFileName": "20071060140",
            "CharacterMotions": [
