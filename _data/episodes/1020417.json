            "EpisodeMasterId": 1020417,
            "Order": 1,
            "GroupOrder": 19,
            "SpeakerName": "大黒",
            "FontSize": 2,
            "Phrase": "それよりも、我が主の素晴らしい脚本に感謝しなさいよね。/nお陰で、エレミアという大役に選ばれたんだから。",
            "VoiceFileName": "10204170190",
            "CharacterMotions": [
