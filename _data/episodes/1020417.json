            "SpeakerIconId": "202"
        },
        {
            "Id": 1020417016,
            "EpisodeMasterId": 1020417,
            "Order": 1,
            "GroupOrder": 16,
            "SpeakerName": "大黒",
            "FontSize": 2,
            "Phrase": "『プロメテウス賞』がかかった大事な公演でダブル主演のひとりに決まって、/n緊張してるのなら、素直にそう言えばいいじゃない。",
            "VoiceFileName": "10204170160",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 103,
                    "BodyMotionMasterId": 21,
                    "LipSyncMasterId": 1,
                    "SpineId": 20203,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "202"
        },
        {
            "Id": 1020417017,
            "EpisodeMasterId": 1020417,
            "Order": 1,
            "GroupOrder": 17,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "そういう大黒先輩こそ、もしかしてしぐれの心配ですかぁ？/n最近とぉってもお節介ですけど、どういう心境の変化ですぅ？",
            "VoiceFileName": "10204170170",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "SpineId": 20203,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 2,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                },
                {
                    "slotNumber": 2,
                    "FacialExpressionMasterId": 600,
                    "BodyMotionMasterId": 28,
                    "LipSyncMasterId": 4,
                    "SpineId": 20503,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 4,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
