            "SpeakerIconId": "203"
        },
        {
            "Id": 1020417014,
            "EpisodeMasterId": 1020417,
            "Order": 1,
            "GroupOrder": 14,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "あぁーもう、余計なこと言わなきゃよかった……。/n仁花子先輩って素直すぎて、こっちが恥ずかしいんですって……。",
            "VoiceFileName": "10204170140",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "SpineId": 20303,
                    "CharacterAppearanceType": 0,
