            "SpeakerIconId": "205"
        },
        {
            "Id": 1020417015,
            "EpisodeMasterId": 1020417,
            "Order": 1,
            "GroupOrder": 15,
            "SpeakerName": "大黒",
            "FontSize": 2,
            "Phrase": "ふんっ、相変わらず素直じゃないガキね。",
