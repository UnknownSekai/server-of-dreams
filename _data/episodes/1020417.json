            "EpisodeMasterId": 1020417,
            "Order": 1,
            "GroupOrder": 18,
            "SpeakerName": "大黒",
            "FontSize": 2,
            "Phrase": "別にっ……あんたみたいな奴でも、/nいなくなったら我が主が困ると思ったから気にしていただけよっ！",
            "VoiceFileName": "10204170180",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 74,
                    "BodyMotionMasterId": 3,
                    "LipSyncMasterId": 3,
                    "SpineId": 20203,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 2,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
