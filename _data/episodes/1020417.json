        {
            "Id": 1020417006,
            "EpisodeMasterId": 1020417,
            "Order": 1,
            "GroupOrder": 6,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "（Edenの未来がかかった公演でもあるし、/n　仁花子先輩はしぐれの事情も知ってる……）",
            "VoiceFileName": "10204170060",
            "CharacterMotions": [
                {
