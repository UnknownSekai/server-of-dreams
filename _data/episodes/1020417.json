        },
        {
            "Id": 1020417007,
            "EpisodeMasterId": 1020417,
            "Order": 1,
            "GroupOrder": 7,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "（だからもっとプレッシャーを感じてるかと思ってたけど、案外平気そうね。/n　……別に、心配してたわけじゃないけど）",
            "VoiceFileName": "10204170070",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "BodyMotionMasterId": 11,
                    "SpineId": 20503,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "205"
        },
        {
            "Id": 1020417008,
            "EpisodeMasterId": 1020417,
            "Order": 1,
            "GroupOrder": 8,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "だって、こんなにも面白そうな台本で、主役をやらせてもらえるんだもん！/n今は嬉しくて、早くお芝居がしたいって気持ちでいっぱいだよっ！",
            "VoiceFileName": "10204170080",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 200,
                    "BodyMotionMasterId": 2,
                    "LipSyncMasterId": 2,
                    "SpineId": 20303,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "203"
        },
        {
            "Id": 1020417009,
            "EpisodeMasterId": 1020417,
            "Order": 1,
            "GroupOrder": 9,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "あっ、もちろん、大事な公演だってことは分かってる……でも、/nだからこそっていうか、硬くなりすぎるのは良くない気がして……。",
            "VoiceFileName": "10204170090",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 400,
                    "BodyMotionMasterId": 11,
                    "LipSyncMasterId": 4,
                    "SpineId": 20303,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "203"
        },
        {
            "Id": 1020417010,
            "EpisodeMasterId": 1020417,
            "Order": 1,
            "GroupOrder": 10,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "はいはい、分かりましたってばぁ。別に、責めてるわけじゃないですよぉ。/nただ、仁花子先輩は相変わらずだなって思っただけなんで。",
            "VoiceFileName": "10204170100",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "SpineId": 20303,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 2,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                },
                {
                    "slotNumber": 2,
                    "FacialExpressionMasterId": 73,
                    "BodyMotionMasterId": 27,
                    "LipSyncMasterId": 4,
                    "SpineId": 20503,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 4,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "205"
        },
        {
            "Id": 1020417011,
            "EpisodeMasterId": 1020417,
            "Order": 1,
            "GroupOrder": 11,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "ははっ……なんかごめんね？/n気持ちは真剣なんだけどっ……！",
            "VoiceFileName": "10204170110",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 103,
                    "BodyMotionMasterId": 20,
                    "LipSyncMasterId": 1,
                    "SpineId": 20303,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 2,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                },
                {
                    "slotNumber": 2,
                    "SpineId": 20503,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 4,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "203"
        },
        {
            "Id": 1020417012,
            "EpisodeMasterId": 1020417,
            "Order": 1,
            "GroupOrder": 12,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "だからぁ、分かってますってば。悪いとは思ってないですよ。/n……どちらかといえば、羨ましいというか……。",
            "VoiceFileName": "10204170120",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "SpineId": 20303,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 2,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                },
                {
                    "slotNumber": 2,
                    "FacialExpressionMasterId": 105,
                    "BodyMotionMasterId": 11,
                    "LipSyncMasterId": 1,
                    "SpineId": 20503,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 4,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "205"
        },
        {
            "Id": 1020417013,
            "EpisodeMasterId": 1020417,
            "Order": 1,
            "GroupOrder": 13,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "へ？　そ、そうかな？/nしぐれちゃんに褒められちゃうと、なんか照れちゃうな！",
            "VoiceFileName": "10204170130",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 114,
                    "BodyMotionMasterId": 6,
                    "LipSyncMasterId": 1,
                    "SpineId": 20303,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 2,
                    "CharacterLayerType": 1,
