            "EpisodeMasterId": 142491,
            "Order": 1,
            "GroupOrder": 17,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "（別に、改変の是非や範囲については明示されていないからな。/n　私をルール違反として追及することも出来まい）",
            "VoiceFileName": "1424910170",
            "CharacterMotions": [
