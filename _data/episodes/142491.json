            "EpisodeMasterId": 142491,
            "Order": 1,
            "GroupOrder": 14,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "フッ……せいぜい楽しみにしているんだな、/n世界演劇リーグの重鎮たちよ。",
            "VoiceFileName": "1424910140",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 71,
                    "BodyMotionMasterId": 24,
                    "LipSyncMasterId": 1,
