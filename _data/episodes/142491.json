            "EpisodeMasterId": 142491,
            "Order": 1,
            "GroupOrder": 9,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "（私は、権勢を振るう者の敷いたレールの上を歩いてやる為に、/n　わざわざ招待を受けたわけではない）",
            "VoiceFileName": "1424910090",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 107,
                    "BodyMotionMasterId": 17,
                    "SpineId": 20103,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "201"
        },
        {
            "Id": 142491010,
            "EpisodeMasterId": 142491,
            "Order": 1,
            "GroupOrder": 10,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "（他の劇団ならば、出された課題を素直に受け入れ、/n　彼女らの指示に従い、そのまま演じるのだろう）",
            "VoiceFileName": "1424910100",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "BodyMotionMasterId": 3,
                    "SpineId": 20103,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
