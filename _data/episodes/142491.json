            "EpisodeMasterId": 142491,
            "Order": 1,
            "GroupOrder": 5,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "……下調べは、きちんとしているようだな。/nフッ、光栄なことだ。",
            "VoiceFileName": "1424910050",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
