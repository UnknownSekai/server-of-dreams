            "EpisodeMasterId": 142491,
            "Order": 1,
            "GroupOrder": 15,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "（私がこのまま、全てをすんなり受け入れるとまでは、/n　彼女らも思っていないだろうが……）",
