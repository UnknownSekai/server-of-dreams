            "SpeakerIconId": "201"
        },
        {
            "Id": 142491012,
            "EpisodeMasterId": 142491,
            "Order": 1,
            "GroupOrder": 12,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "（我々は、『本当の舞台』を演劇界に示す場として、/n　世界演劇リーグという場を選んだまで）",
            "VoiceFileName": "1424910120",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 107,
                    "SpineId": 20103,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
