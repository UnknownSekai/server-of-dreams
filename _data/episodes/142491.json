            "EpisodeMasterId": 142491,
            "Order": 1,
            "GroupOrder": 7,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "先に逸脱する幅を明示する事で、私の劇団を呑み込もうという気か。/n……くくっ、面白い。",
            "VoiceFileName": "1424910070",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 103,
                    "BodyMotionMasterId": 7,
                    "LipSyncMasterId": 1,
                    "SpineId": 20103,
