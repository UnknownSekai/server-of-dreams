            "EpisodeMasterId": 142491,
            "Order": 1,
            "GroupOrder": 4,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "（全体の方向性、脚本の雰囲気は、我々が普段演じているものとも近い）",
            "VoiceFileName": "1424910040",
            "CharacterMotions": [
                {
