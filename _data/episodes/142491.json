            "SpeakerIconId": "201"
        },
        {
            "Id": 142491013,
            "EpisodeMasterId": 142491,
            "Order": 1,
            "GroupOrder": 13,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "（センスに頼るばかりではない……脚本、美術、演出などの、/n　全ての要素が揃うことで、現代の渇きを潤す、真の舞台は出来上がる）",
            "VoiceFileName": "1424910130",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "BodyMotionMasterId": 15,
                    "SpineId": 20103,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
