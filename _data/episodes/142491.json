            "EpisodeMasterId": 142491,
            "Order": 1,
            "GroupOrder": 11,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "（でも私のEdenは、そんなつまらないものを享受するつもりはない。/n　そんなもので世界からの評価を得る事など、望みはしないさ）",
            "VoiceFileName": "1424910110",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 74,
                    "SpineId": 20103,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
