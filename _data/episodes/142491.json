            "EpisodeMasterId": 142491,
            "Order": 1,
            "GroupOrder": 16,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "（その予想すらも凌駕し、観客全員の度肝を抜いてみせよう）",
            "VoiceFileName": "1424910160",
            "CharacterMotions": [
