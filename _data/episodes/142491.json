            "EpisodeMasterId": 142491,
            "Order": 1,
            "GroupOrder": 3,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "（星座のモチーフになっている神話を元にした、オリジナル脚本。/n　これを、Edenは披露する事になる……）",
            "VoiceFileName": "1424910030",
            "CharacterMotions": [
