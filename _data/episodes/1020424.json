            "EpisodeMasterId": 1020424,
            "Order": 1,
            "GroupOrder": 20,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "（Edenが『プロメテウス賞』を受賞して、/n　しぐれちゃんもEdenに残れることになって……）",
