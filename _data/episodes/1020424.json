        {
            "Id": 1020424013,
            "EpisodeMasterId": 1020424,
            "Order": 1,
            "GroupOrder": 13,
            "SpeakerName": "クラスメイトＡ",
            "FontSize": 2,
            "Phrase": "舎人さん、ナントカ賞の受賞おめでとう！/nしかも主演だったよね！　観たよ、舞台！　カッコ良かった～！",
            "VoiceFileName": "10204240120",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020424014,
            "EpisodeMasterId": 1020424,
            "Order": 1,
            "GroupOrder": 14,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "ありがとう！/nしかも観に来てくれてたなんて……すっごく嬉しいよぉ！",
            "VoiceFileName": "10204240130",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 202,
                    "BodyMotionMasterId": 2,
                    "LipSyncMasterId": 2,
                    "SpineId": 20302,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
