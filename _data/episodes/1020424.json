            "SpeakerIconId": "203"
        },
        {
            "Id": 1020424016,
            "EpisodeMasterId": 1020424,
            "Order": 1,
            "GroupOrder": 16,
            "SpeakerName": "クラスメイトＢ",
            "FontSize": 2,
            "Phrase": "仁花子の悪役のお芝居、凄かったもんね～。/n海外で評価されたのも納得って感じ！",
            "VoiceFileName": "10204240150",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020424017,
            "EpisodeMasterId": 1020424,
            "Order": 1,
            "GroupOrder": 17,
            "SpeakerName": "クラスメイトＣ",
            "FontSize": 2,
            "Phrase": "そうそう、前半は艶めいていて、かつ後半はホント怖くって！/n全然いつもの仁花子っぽくなくって、新鮮だったよ～。",
            "VoiceFileName": "10204240160",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020424018,
            "EpisodeMasterId": 1020424,
            "Order": 1,
            "GroupOrder": 18,
            "SpeakerName": "クラスメイトＡ",
            "FontSize": 2,
            "Phrase": "それ、この前も言ってたよね。",
            "VoiceFileName": "10204240170",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020424019,
            "EpisodeMasterId": 1020424,
            "Order": 1,
            "GroupOrder": 19,
            "SpeakerName": "仁花子",
            "FontSize": 2,
