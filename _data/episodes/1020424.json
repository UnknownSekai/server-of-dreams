    "Chapter": "Eden　4章",
    "Title": "次なる舞台へ",
    "EpisodeDetail": [
        {
            "Id": 1020424001,
            "EpisodeMasterId": 1020424,
            "Order": 1,
            "GroupOrder": 1,
            "SpeakerName": "司会",
            "FontSize": 2,
            "Phrase": "暗闇に閉ざされた世界を照らした火、それをもたらしたプロメテウス。",
            "BackgroundImageFileName": "1170",
            "BgmFileName": "405",
            "VoiceFileName": "10204240010",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020424002,
            "EpisodeMasterId": 1020424,
            "Order": 1,
            "GroupOrder": 2,
            "SpeakerName": "司会",
            "FontSize": 2,
            "Phrase": "本賞は演劇界の常識を覆し、/n私たちの心に消えることのない情熱を吹き込んだ劇団に贈られます。",
            "VoiceFileName": "10204240020",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020424003,
            "EpisodeMasterId": 1020424,
            "Order": 1,
            "GroupOrder": 3,
            "SpeakerName": "司会",
            "FontSize": 2,
            "Phrase": "本年度、演劇の枠組みを押し広げ、観る者の魂に鋭い一石を投じたのは……、/nこの劇団です。",
            "VoiceFileName": "10204240030",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020424004,
            "EpisodeMasterId": 1020424,
            "Order": 1,
            "GroupOrder": 4,
            "SpeakerName": "司会",
            "FontSize": 2,
            "Phrase": "第34回プロメテウス賞受賞、劇団Eden！/nおめでとうございます！",
            "VoiceFileName": "10204240040",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020424005,
            "EpisodeMasterId": 1020424,
            "Order": 1,
            "GroupOrder": 5,
            "SpeakerName": "司会",
            "FontSize": 2,
            "Phrase": "『青髭』という物語が持つ暴力性と倒錯した愛を、独自解釈と独創的な演出で/n新たな演目へと昇華した、その手腕は素晴らしいの一言に尽きる。",
            "VoiceFileName": "10204240050",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020424006,
            "EpisodeMasterId": 1020424,
            "Order": 1,
            "GroupOrder": 6,
            "SpeakerName": "司会",
            "FontSize": 2,
            "Phrase": "その圧倒的な創造性は、舞台と客席の境界をも消し去り、/n私たちに言葉を越えた衝撃を与えてくれました。",
            "VoiceFileName": "10204240060",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020424007,
            "EpisodeMasterId": 1020424,
            "Order": 1,
            "GroupOrder": 7,
            "SpeakerName": "司会",
            "FontSize": 2,
            "Phrase": "それでは、劇団を代表いたしまして、連尺野初魅様。/nどうぞ、ステージへとお上がりください。",
            "VoiceFileName": "10204240070",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020424008,
            "EpisodeMasterId": 1020424,
            "Order": 1,
            "GroupOrder": 8,
            "SpeakerName": "司会",
            "FontSize": 2,
            "Phrase": "皆様、今一度、称賛の火を灯すような盛大な拍手でお迎えください！",
            "VoiceFileName": "10204240080",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020424009,
            "EpisodeMasterId": 1020424,
            "Order": 1,
            "GroupOrder": 9,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "ありがとうございます。/nこのような場に立てたこと、光栄に存じます。",
            "VoiceFileName": "10204240090",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 103,
                    "HeadMotionMasterId": 1,
                    "BodyMotionMasterId": 13,
                    "LipSyncMasterId": 1,
                    "SpineId": 20101,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "201"
        },
        {
            "Id": 1020424010,
            "EpisodeMasterId": 1020424,
            "Order": 1,
            "GroupOrder": 10,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "この賞は役者及び、スタッフ一同の尽力があってこそでございます。/n……お前たちも、本当にありがとう。",
            "VoiceFileName": "10204240100",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 71,
                    "BodyMotionMasterId": 15,
                    "LipSyncMasterId": 1,
                    "SpineId": 0,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "201"
        },
        {
            "Id": 1020424011,
            "EpisodeMasterId": 1020424,
            "Order": 1,
            "GroupOrder": 11,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "これからも現状に甘んじることなく、/nより素晴らしい舞台を追求していくことをここに誓い――",
            "VoiceFileName": "10204240110",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 103,
                    "BodyMotionMasterId": 14,
                    "LipSyncMasterId": 1,
                    "SpineId": 0,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "201"
        },
        {
