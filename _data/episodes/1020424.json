            ],
            "SpeakerIconId": "203"
        },
        {
            "Id": 1020424015,
            "EpisodeMasterId": 1020424,
            "Order": 1,
            "GroupOrder": 15,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "劇団のみんなにも、クラスの子が来てくれたんだよって伝えておくねっ！/n絶対みんな喜ぶと思うから！",
            "VoiceFileName": "10204240140",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 103,
                    "BodyMotionMasterId": 20,
                    "LipSyncMasterId": 2,
                    "SpineId": 0,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
