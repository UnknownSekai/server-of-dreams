            "EpisodeMasterId": 142432,
            "Order": 1,
            "GroupOrder": 5,
            "SpeakerName": "Edenスタッフ３",
            "FontSize": 2,
            "Phrase": "いいえ、私のよ！　あんたたちには絶対に渡すもんですか！",
            "VoiceFileName": "1424320050",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
