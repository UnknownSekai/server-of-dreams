            "EpisodeMasterId": 142432,
            "Order": 1,
            "GroupOrder": 3,
            "SpeakerName": "Edenスタッフ１",
            "FontSize": 2,
            "Phrase": "よーし！/n絶対にあのブーケを取って、次は私が結婚式を挙げてみせるっ！",
