            "EpisodeMasterId": 1020416,
            "Order": 1,
            "GroupOrder": 18,
            "SpeakerName": "大黒",
            "FontSize": 2,
            "Phrase": "（なんてゾクゾクするお話なのかしら……！/n　素晴らしいです、我が主……！）",
