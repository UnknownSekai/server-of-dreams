        },
        {
            "Id": 1020416024,
            "EpisodeMasterId": 1020416,
            "Order": 1,
            "GroupOrder": 24,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "お前たちなら、この脚本の良さを理解してくれていると思っていたよ。/nこれこそ、我がEdenの真骨頂を見せる舞台だ。",
