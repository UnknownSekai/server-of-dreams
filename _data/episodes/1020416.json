            "EpisodeMasterId": 1020416,
            "Order": 1,
            "GroupOrder": 22,
            "SpeakerName": "大黒",
            "FontSize": 2,
            "Phrase": "これが、我が主ならではの青ひげ……。/n見事な再解釈、再構築です……。",
