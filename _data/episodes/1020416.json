            "EpisodeMasterId": 1020416,
            "Order": 1,
            "GroupOrder": 19,
            "SpeakerName": "容",
            "FontSize": 2,
            "Phrase": "業と報いってやつだね。/n確かに、サスペンス色が強い舞台になってる。初魅らしい。",
