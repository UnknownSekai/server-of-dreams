            "EpisodeMasterId": 1020416,
            "Order": 1,
            "GroupOrder": 17,
            "SpeakerName": "大黒",
            "FontSize": 2,
            "Phrase": "エレミアを人質にとった青髪公は、独善的な愛により……、/n先妻の霊に引きずられて塔から落ちる……。",
            "VoiceFileName": "10204160160",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 73,
                    "BodyMotionMasterId": 3,
                    "LipSyncMasterId": 4,
                    "SpineId": 20203,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
