            "SpeakerIconId": "201"
        },
        {
            "Id": 1020416025,
            "EpisodeMasterId": 1020416,
            "Order": 1,
            "GroupOrder": 25,
            "SpeakerName": "容",
            "FontSize": 2,
            "Phrase": "そうだね。独創性もあるし、あとは役作りと美術にかかってるけど……。/nこれなら、プロメテウス賞に挑むに相応しい舞台なんじゃないかな。",
            "VoiceFileName": "10204160240",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "SpineId": 20103,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 2,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
