            "EpisodeMasterId": 1020416,
            "Order": 1,
            "GroupOrder": 20,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "エレミアを助けに駆けつけた兄の竜騎兵は、/n原作と違って、この青髪公を倒せてないんですね。",
