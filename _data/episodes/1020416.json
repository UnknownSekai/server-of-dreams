            "EpisodeMasterId": 1020416,
            "Order": 1,
            "GroupOrder": 26,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "（脚本は完璧……あとは役作りに、賞の獲得がかかってる……。/n　主演級の役なら、なおさら重要よね……）",
            "VoiceFileName": "10204160250",
            "CharacterMotions": [
