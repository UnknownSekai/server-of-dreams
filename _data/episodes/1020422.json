            "EpisodeMasterId": 1020422,
            "Order": 1,
            "GroupOrder": 38,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "（なんだかいつもより嬉しそうに見える……。/n　お仕事が上手くいったから？）",
            "VoiceFileName": "10204220350",
            "CharacterMotions": [
                {
