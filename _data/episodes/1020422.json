            "EpisodeMasterId": 1020422,
            "Order": 1,
            "GroupOrder": 41,
            "SpeakerName": "しぐれの父",
            "FontSize": 2,
            "Phrase": "取引先の方が、しぐれの劇団のファンだそうでな。/n芝居を観に連れて行ってもらった。",
            "VoiceFileName": "10204220380",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020422042,
            "EpisodeMasterId": 1020422,
            "Order": 1,
            "GroupOrder": 42,
            "SpeakerName": "しぐれの母",
            "FontSize": 2,
            "Phrase": "パパから聞いたわよ。/nしぐれのお芝居、その方に凄く褒めていただいたって。",
            "VoiceFileName": "10204220390",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
