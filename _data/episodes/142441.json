        },
        {
            "Id": 142441002,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 2,
            "SpeakerName": "雪",
            "FontSize": 2,
            "Phrase": "（とりあえず、ケータリング用の料理をテーブルに並べたら、/n　会場の装飾に取り掛かって、と……）",
            "VoiceFileName": "1424410020",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "BodyMotionMasterId": 11,
                    "SpineId": 30306,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "303"
        },
        {
            "Id": 142441003,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 3,
            "FontSize": 2,
            "Phrase": "",
            "SeFileName": "50",
            "CharacterMotions": []
        },
        {
            "Id": 142441004,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 4,
            "SpeakerName": "スタッフ１",
            "FontSize": 2,
            "Phrase": "……はい、もしもし……ええっ！？　そうなんですか！？/nそれで到着は……えええっ！？　来られない！？",
            "VoiceFileName": "1424410030",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142441005,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 5,
            "SpeakerName": "スタッフ１",
            "FontSize": 2,
            "Phrase": "わ、分かりました！　すぐに確認します！/n……あの！　プロデューサー！",
            "BgmFileName": "999",
            "VoiceFileName": "1424410040",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142441006,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 6,
            "SpeakerName": "プロデューサー",
            "FontSize": 2,
            "Phrase": "なんだ、どうした？　トラブルか？",
            "BgmFileName": "29",
            "VoiceFileName": "1424410050",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142441007,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 7,
            "SpeakerName": "スタッフ１",
            "FontSize": 2,
            "Phrase": "はい、それが……。/n今日、撮影を予定していたモデルのリサさんですが……。",
            "VoiceFileName": "1424410060",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142441008,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 8,
            "SpeakerName": "スタッフ１",
            "FontSize": 2,
            "Phrase": "海外ロケから朝イチの飛行機でこちらに戻る予定が……、/n悪天候のせいで全て欠航となっているらしくて……。",
            "VoiceFileName": "1424410070",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142441009,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 9,
            "SpeakerName": "スタッフ１",
            "FontSize": 2,
            "Phrase": "撮影には、間に合いそうにないとかで……。",
            "VoiceFileName": "1424410080",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142441010,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 10,
            "SpeakerName": "プロデューサー",
            "FontSize": 2,
            "Phrase": "なっ……なんだと！？　おいおい、どうするんだ！/nメインのモデルがいなきゃ、撮影にならんぞ！",
            "VoiceFileName": "1424410090",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142441011,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 11,
            "SpeakerName": "スタッフ１",
            "FontSize": 2,
            "Phrase": "そ、そうなんですが……。",
            "VoiceFileName": "1424410100",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142441012,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 12,
            "SpeakerName": "スタッフ２",
            "FontSize": 2,
            "Phrase": "嘘だろ、どうすんだよ……。",
            "VoiceFileName": "1424410110",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142441013,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 13,
            "SpeakerName": "スタッフ３",
            "FontSize": 2,
            "Phrase": "メイクスタッフも準備万端だったのに、今日はバラしになりそうね。",
            "VoiceFileName": "1424410120",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142441014,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 14,
            "SpeakerName": "雪",
            "FontSize": 2,
            "Phrase": "（ん？　なんだ？　何かトラブルか？/n　……まさか、ケータリングはキャンセルになったりしないだろうな）",
            "VoiceFileName": "1424410130",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 102,
                    "BodyMotionMasterId": 6,
                    "SpineId": 30306,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "303"
        },
        {
            "Id": 142441015,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 15,
            "SpeakerName": "雪",
            "FontSize": 2,
            "Phrase": "（せっかく朝からスタッフ総出で作ったんだ……！/n　何があったか知らんが、せめてこれだけは食べてくれよな……！）",
            "VoiceFileName": "1424410140",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 74,
                    "BodyMotionMasterId": 3,
                    "SpineId": 30306,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "303"
        },
        {
            "Id": 142441016,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 16,
            "SpeakerName": "雪",
            "FontSize": 2,
            "Phrase": "（まあいい。トラブルならば、後で指示があるだろう。/n　それまでワタシは、ワタシのやるべきことに努めよう）",
            "VoiceFileName": "1424410150",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 100,
                    "BodyMotionMasterId": 15,
                    "SpineId": 30306,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "303"
        },
        {
            "Id": 142441017,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 17,
            "SpeakerName": "プロデューサー",
            "FontSize": 2,
            "Phrase": "はぁぁ……せめて代役が見つかりさえすれば、解決するんだが……。/nこのドレスを着こなせる、小柄で身軽そうなモデルが……。",
            "VoiceFileName": "1424410160",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142441018,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 18,
            "SpeakerName": "雪",
            "FontSize": 2,
            "Phrase": "（空いたテーブルには花瓶を並べて……次は……）",
            "VoiceFileName": "1424410170",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 102,
                    "BodyMotionMasterId": 11,
                    "SpineId": 30306,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "303"
        },
        {
            "Id": 142441019,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 19,
            "SpeakerName": "プロデューサー",
            "FontSize": 2,
            "Phrase": "ん？",
            "VoiceFileName": "1424410180",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142441020,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 20,
            "SpeakerName": "プロデューサー",
            "FontSize": 2,
            "Phrase": "（なんだあの子……。/n　式場スタッフの制服を着ながらも、あの身軽な身のこなし……）",
            "VoiceFileName": "1424410190",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142441021,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 21,
            "SpeakerName": "プロデューサー",
            "FontSize": 2,
            "Phrase": "（しかも細身で小柄、リサの体型にも近いな……）",
            "VoiceFileName": "1424410200",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142441022,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 22,
            "SpeakerName": "プロデューサー",
            "FontSize": 2,
            "Phrase": "（それに容姿にも華がある……というか、どこかで見た顔じゃないか？/n　どっかの劇団の取材で取り上げられていたような……）",
            "VoiceFileName": "1424410210",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142441023,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 23,
            "SpeakerName": "プロデューサー",
            "FontSize": 2,
            "Phrase": "おい。/nあの子……あの式場スタッフの子の名前はなんて言うんだ？",
            "VoiceFileName": "1424410220",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142441024,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 24,
            "SpeakerName": "スタッフ１",
            "FontSize": 2,
            "Phrase": "えっ？　いや、ちょっと分からないですね……。",
            "VoiceFileName": "1424410230",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142441025,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 25,
            "SpeakerName": "プロデューサー",
            "FontSize": 2,
            "Phrase": "そこの……テーブルに花瓶を並べてる、明るい髪色の君！",
            "VoiceFileName": "1424410240",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142441026,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 26,
            "SpeakerName": "雪",
            "FontSize": 2,
            "Phrase": "？　花瓶を並べている……というのは、ワタシのことか？/n……はい、なんでしょうか。",
            "VoiceFileName": "1424410250",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 102,
                    "BodyMotionMasterId": 13,
                    "LipSyncMasterId": 4,
                    "SpineId": 30306,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "303"
        },
        {
            "Id": 142441027,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 27,
            "SpeakerName": "プロデューサー",
            "FontSize": 2,
            "Phrase": "キミ、ちょっとそこに立ってみてくれないか？/nカメラの配置された……そう、そこだ！",
            "VoiceFileName": "1424410260",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142441028,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 28,
            "SpeakerName": "雪",
            "FontSize": 2,
            "Phrase": "（モデルの立ち位置の確認でもしたいのか？/n　まったく……撮影スタッフにでも頼めば良いものを……）",
            "VoiceFileName": "1424410270",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 74,
                    "BodyMotionMasterId": 7,
                    "SpineId": 30306,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "303"
        },
        {
            "Id": 142441029,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 29,
            "SpeakerName": "雪",
            "FontSize": 2,
            "Phrase": "ええと……ここで合ってますか？",
            "VoiceFileName": "1424410280",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 102,
                    "BodyMotionMasterId": 11,
                    "LipSyncMasterId": 4,
                    "SpineId": 30306,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "303"
        },
        {
            "Id": 142441030,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 30,
            "SpeakerName": "プロデューサー",
            "FontSize": 2,
            "Phrase": "そうそう！　……おいスタッフ！　全員集まってくれ！",
            "BgmFileName": "201",
            "VoiceFileName": "1424410290",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142441031,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 31,
            "SpeakerName": "雪",
            "FontSize": 2,
            "Phrase": "（！？　なんだ！？　今度はなんの騒ぎだ……！？）",
            "VoiceFileName": "1424410300",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 500,
                    "BodyMotionMasterId": 13,
                    "SpineId": 30306,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "303"
        },
        {
            "Id": 142441032,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 32,
            "SpeakerName": "プロデューサー",
            "FontSize": 2,
            "Phrase": "どうだ、皆？　代役にピッタリだと思わないか？",
            "VoiceFileName": "1424410310",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142441033,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 33,
            "SpeakerName": "スタッフ１",
            "FontSize": 2,
            "Phrase": "うわあ……いいですねぇ……！/n今回の撮影のイメージにも合ってますよ！",
            "VoiceFileName": "1424410320",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142441034,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 34,
            "SpeakerName": "スタッフ２",
            "FontSize": 2,
            "Phrase": "ええ。体型も丁度良さそうですし、/n本人さえ良ければ、いいんじゃないでしょうか。",
            "VoiceFileName": "1424410330",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142441035,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 35,
            "SpeakerName": "スタッフ３",
            "FontSize": 2,
            "Phrase": "メイクしたら、より映えそうね。気合入るわぁ。",
            "VoiceFileName": "1424410340",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142441036,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 36,
            "SpeakerName": "プロデューサー",
            "FontSize": 2,
            "Phrase": "……というわけで君。/nいきなりですまないが、代役としてモデルを務めてくれないか？",
            "VoiceFileName": "1424410350",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142441037,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 37,
            "SpeakerName": "プロデューサー",
            "FontSize": 2,
            "Phrase": "式場の責任者には、私から説明しておこう！/nきちんと報酬も支払う！　だから……頼む！　この通りだ！",
            "VoiceFileName": "1424410360",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142441038,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 38,
            "SpeakerName": "雪",
            "FontSize": 2,
            "Phrase": "な、なにっ……！？",
            "VoiceFileName": "1424410370",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 500,
                    "BodyMotionMasterId": 5,
                    "LipSyncMasterId": 3,
                    "SpineId": 30306,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "303"
        },
        {
            "Id": 142441039,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 39,
            "SpeakerName": "プロデューサー",
            "FontSize": 2,
            "Phrase": "戸惑うのも無理はないだろう！/nだがしかし……君しかもう頼れる人はいないんだ！　お願いします！",
            "VoiceFileName": "1424410380",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142441040,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 40,
            "SpeakerName": "スタッフたち",
            "FontSize": 2,
            "Phrase": "お願いしますっっ！！！！！",
            "VoiceFileName": "1424410390",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142441041,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 41,
            "SpeakerName": "雪",
            "FontSize": 2,
            "Phrase": "うっ……。",
            "VoiceFileName": "1424410400",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 400,
                    "BodyMotionMasterId": 25,
                    "LipSyncMasterId": 4,
                    "SpineId": 30306,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "303"
        },
        {
            "Id": 142441042,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 42,
            "SpeakerName": "雪",
            "FontSize": 2,
            "Phrase": "（報酬も出る……。となると、飛びつきたいところだが……、/n　劇団を通さずに撮影を受けるのは、流石にマズいよな……）",
            "VoiceFileName": "1424410410",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "BodyMotionMasterId": 7,
                    "SpineId": 30306,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "303"
        },
        {
            "Id": 142441043,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 43,
            "SpeakerName": "雪",
            "FontSize": 2,
            "Phrase": "その、ワタシは銀河座に所属してるので……、/nワタシの一存で雑誌の仕事は……。",
            "VoiceFileName": "1424410420",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 400,
                    "BodyMotionMasterId": 13,
                    "LipSyncMasterId": 4,
                    "SpineId": 30306,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "303"
        },
        {
            "Id": 142441044,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 44,
            "SpeakerName": "プロデューサー",
            "FontSize": 2,
            "Phrase": "む、やはりそうか！　通りで見覚えがあると……、/nしかし銀河座か……ふむ、なるほど。",
            "VoiceFileName": "1424410430",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142441045,
            "EpisodeMasterId": 142441,
            "Order": 1,
            "GroupOrder": 45,
            "SpeakerName": "スタッフ１",
            "FontSize": 2,
            "Phrase": "どうしましょうか、プロデューサー……？",
            "VoiceFileName": "1424410440",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142441046,
