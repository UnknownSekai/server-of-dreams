            "GroupOrder": 1,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "『……今、目の前にいるあなたは、/n　周囲の方々が噂する青髪伯爵とは思えません』",
            "BackgroundImageFileName": "150",
            "BackgroundCharacterImageFileName": "142450_0",
            "BgmFileName": "32",
            "VoiceFileName": "10204210010",
            "CharacterMotions": [],
            "SpeakerIconId": "205"
        },
        {
            "Id": 1020421002,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 2,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "『何を耳にしてきたかは聞かないが、/n　今宵は噂などではなく、本当の私を見てくれ』",
            "BackgroundCharacterImageFileName": "142450_0",
            "VoiceFileName": "10204210020",
            "CharacterMotions": [],
            "SpeakerIconId": "203"
        },
        {
            "Id": 1020421003,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 3,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "『あなたのためならば、私は毎晩でもこんな宴を準備しよう』",
            "BackgroundCharacterImageFileName": "142450_0",
            "VoiceFileName": "10204210030",
            "CharacterMotions": [],
            "SpeakerIconId": "203"
        },
        {
            "Id": 1020421004,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 4,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "『毎晩……。/n　それほどまでに私を……？』",
            "BackgroundCharacterImageFileName": "142450_0",
            "VoiceFileName": "10204210040",
            "CharacterMotions": [],
            "SpeakerIconId": "205"
        },
        {
            "Id": 1020421005,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 5,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "『私のすべてを捧げると誓おう。/n　改めて、妻になってはくれないか、エレミア』",
            "BackgroundCharacterImageFileName": "142450_0",
            "VoiceFileName": "10204210050",
            "CharacterMotions": [],
            "SpeakerIconId": "203"
        },
        {
            "Id": 1020421006,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 6,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "『……はい、青髪伯爵』",
            "BackgroundCharacterImageFileName": "142450_0",
            "VoiceFileName": "10204210060",
            "CharacterMotions": [],
            "SpeakerIconId": "205"
        },
        {
            "Id": 1020421007,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 7,
            "FontSize": 2,
            "Phrase": "",
            "BackgroundImageFileName": "163",
            "BackgroundImageFileFadeType": 1,
            "CharacterMotions": [],
            "FadeValue1": 0.20000000298023224,
            "FadeValue2": 0.30000001192092896,
            "FadeValue3": 0.20000000298023224
        },
        {
            "Id": 1020421008,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 8,
            "SpeakerName": "取引先経営者",
            "FontSize": 2,
            "Phrase": "おお……見ましたか、筆島さん。/n娘さんの芝居を。",
            "VoiceFileName": "10204210070",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020421009,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 9,
            "SpeakerName": "しぐれの父",
            "FontSize": 2,
            "Phrase": "え？　ええ……。",
            "VoiceFileName": "10204210080",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020421010,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 10,
            "SpeakerName": "取引先経営者",
            "FontSize": 2,
            "Phrase": "警戒心を覗かせていたエレミアの表情が、/n魔法にでもかかったかのように青髪に惹かれて変化した……！",
            "VoiceFileName": "10204210090",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020421011,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 11,
            "SpeakerName": "しぐれの父",
            "FontSize": 2,
            "Phrase": "（……私は今まで、何も知らなかった……）",
            "VoiceFileName": "10204210100",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020421012,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 12,
            "SpeakerName": "しぐれの父",
            "FontSize": 2,
            "Phrase": "（舞台に立っている時のお前は、/n　こんなに豊かな表情を見せるのか……しぐれ）",
            "VoiceFileName": "10204210110",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020421013,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 13,
            "FontSize": 2,
            "Phrase": "",
            "BackgroundImageFileName": "150",
            "BackgroundImageFileFadeType": 1,
            "BgmFileName": "22",
            "CharacterMotions": [],
            "FadeValue1": 0.20000000298023224,
            "FadeValue2": 0.30000001192092896,
            "FadeValue3": 0.20000000298023224
        },
        {
            "Id": 1020421014,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 14,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "『落ちて……！/n　お願い……鍵の汚れよ、落ちて……！』",
            "VoiceFileName": "10204210120",
            "CharacterMotions": [],
            "SpeakerIconId": "205"
        },
        {
            "Id": 1020421015,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 15,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "『血じゃない……鍵についたこれは、ただの汚れよ……！/n　ただの汚れ……なのに……』",
            "VoiceFileName": "10204210130",
            "CharacterMotions": [],
            "SpeakerIconId": "205"
        },
        {
            "Id": 1020421016,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 16,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "『どうして……どうして消えないの……！』",
            "VoiceFileName": "10204210140",
            "CharacterMotions": [],
            "SpeakerIconId": "205"
        },
        {
            "Id": 1020421017,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 17,
            "SpeakerName": "大黒",
            "FontSize": 2,
            "Phrase": "『……消えるはずがないわ』",
            "VoiceFileName": "10204210150",
            "CharacterMotions": [],
            "SpeakerIconId": "202"
        },
        {
            "Id": 1020421018,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 18,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "『だ、誰……！？　どこにいるの……！？』",
            "VoiceFileName": "10204210160",
            "CharacterMotions": [],
            "SpeakerIconId": "205"
        },
        {
            "Id": 1020421019,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 19,
            "SpeakerName": "容",
            "FontSize": 2,
            "Phrase": "『私たちは……かつてのあなた……。/n　その赤黒い汚れは「見てしまった者」の印……』",
            "VoiceFileName": "10204210170",
            "CharacterMotions": [],
            "SpeakerIconId": "204"
        },
        {
            "Id": 1020421020,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 20,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "『ち、違う……！/n　私は、何も見てなんかいない……！』",
            "VoiceFileName": "10204210180",
            "CharacterMotions": [],
            "SpeakerIconId": "205"
        },
        {
            "Id": 1020421021,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 21,
            "SpeakerName": "大黒",
            "FontSize": 2,
            "Phrase": "『私たちも、あのとき……そう言った……。/n　でも……』",
            "VoiceFileName": "10204210190",
            "CharacterMotions": [],
            "SpeakerIconId": "202"
        },
        {
            "Id": 1020421022,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 22,
            "SpeakerName": "容",
            "FontSize": 2,
            "Phrase": "『愛されていると、信じていたのに……。/n　それなのに……』",
            "VoiceFileName": "10204210200",
            "CharacterMotions": [],
            "SpeakerIconId": "204"
        },
        {
            "Id": 1020421023,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 23,
            "SpeakerName": "大黒",
            "FontSize": 2,
            "Phrase": "『……その鍵は、あなたをあの部屋へ導いた』",
            "VoiceFileName": "10204210210",
            "CharacterMotions": [],
            "SpeakerIconId": "202"
        },
        {
            "Id": 1020421024,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 24,
            "SpeakerName": "容",
            "FontSize": 2,
            "Phrase": "『そして、彼をも導いてしまう……』",
            "VoiceFileName": "10204210220",
            "CharacterMotions": [],
            "SpeakerIconId": "204"
        },
        {
            "Id": 1020421025,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 25,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "『ああ……青髪伯爵が帰ってきてしまった……。/n　神様、どうかお願い……助けて……』",
            "VoiceFileName": "10204210230",
            "CharacterMotions": [],
            "SpeakerIconId": "205"
        },
        {
            "Id": 1020421026,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 26,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "『エレミア……何をしている？』",
            "VoiceFileName": "10204210240",
            "CharacterMotions": [],
            "SpeakerIconId": "203"
        },
        {
            "Id": 1020421027,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 27,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "『ひっ――』",
            "VoiceFileName": "10204210250",
            "CharacterMotions": [],
            "SpeakerIconId": "205"
        },
        {
            "Id": 1020421028,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 28,
            "FontSize": 2,
            "Phrase": "",
            "BackgroundImageFileName": "1050",
            "BackgroundImageFileFadeType": 1,
            "CharacterMotions": [],
            "FadeValue1": 0.20000000298023224,
            "FadeValue2": 0.30000001192092896,
            "FadeValue3": 0.20000000298023224
        },
        {
            "Id": 1020421029,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 29,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "『……』",
            "VoiceFileName": "10204210260",
            "CharacterMotions": [],
            "SpeakerIconId": "205"
        },
        {
            "Id": 1020421030,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 30,
            "FontSize": 2,
            "Phrase": "",
            "BackgroundImageFileName": "150",
            "BackgroundCharacterImageFileName": "142460_0",
            "BackgroundImageFileFadeType": 1,
            "CharacterMotions": [],
            "FadeValue1": 0.20000000298023224,
            "FadeValue2": 0.30000001192092896,
            "FadeValue3": 0.20000000298023224
        },
        {
            "Id": 1020421031,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 31,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "『お、お願いです、伯爵……！/n　どうかお許しを……！』",
            "BackgroundCharacterImageFileName": "142460_0",
            "VoiceFileName": "10204210270",
            "CharacterMotions": [],
            "SpeakerIconId": "205"
        },
        {
            "Id": 1020421032,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 32,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "『許し？　何を許せと？/n　あなたは何も咎められるようなことなどしていないはずでは？』",
            "BackgroundCharacterImageFileName": "142460_0",
            "VoiceFileName": "10204210280",
            "CharacterMotions": [],
            "SpeakerIconId": "203"
        },
        {
            "Id": 1020421033,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 33,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "『……で、ですが……私はあの部屋の鍵を……』",
            "BackgroundCharacterImageFileName": "142460_0",
            "VoiceFileName": "10204210290",
            "CharacterMotions": [],
            "SpeakerIconId": "205"
        },
        {
            "Id": 1020421034,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 34,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "『そう、見たのだろう？/n　私こそが罪人だ。あなたではない』",
            "BackgroundCharacterImageFileName": "142460_0",
            "VoiceFileName": "10204210300",
            "CharacterMotions": [],
            "SpeakerIconId": "203"
        },
        {
            "Id": 1020421035,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 35,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "『だが私たちは愛を誓い合った伴侶。/n　罪は共に背負おう』",
            "BackgroundCharacterImageFileName": "142460_0",
            "VoiceFileName": "10204210310",
            "CharacterMotions": [],
            "SpeakerIconId": "203"
        },
        {
            "Id": 1020421036,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 36,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "『よせっ！/n　今すぐ妹を解放しろ、青髪！』",
            "BackgroundCharacterImageFileName": "142460_0",
            "VoiceFileName": "10204210320",
            "CharacterMotions": [],
            "SpeakerIconId": "201"
        },
        {
            "Id": 1020421037,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 37,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "『お兄様……！』",
            "BackgroundCharacterImageFileName": "142460_0",
            "VoiceFileName": "10204210330",
            "CharacterMotions": [],
            "SpeakerIconId": "205"
        },
        {
            "Id": 1020421038,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 38,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "『剣を引け、無粋な竜騎兵。/n　愛するふたりの間に立ち入ることは許さぬ』",
            "BackgroundCharacterImageFileName": "142460_0",
            "VoiceFileName": "10204210340",
            "CharacterMotions": [],
            "SpeakerIconId": "203"
        },
        {
            "Id": 1020421039,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 39,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "『戯言を……！/n　貴様が妹に向けるそれは、愛などではない！』",
            "BackgroundCharacterImageFileName": "142460_0",
            "VoiceFileName": "10204210350",
            "CharacterMotions": [],
            "SpeakerIconId": "201"
        },
        {
            "Id": 1020421040,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 40,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "『まぎれもない愛だよ。その証を見せてやろう。/n　さあ、我が7番目の妻よ。口づけを――』",
            "BackgroundCharacterImageFileName": "142460_0",
            "VoiceFileName": "10204210360",
            "CharacterMotions": [],
            "SpeakerIconId": "203"
        },
        {
            "Id": 1020421041,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 41,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "『っ！？』",
            "BackgroundCharacterImageFileName": "142460_0",
            "VoiceFileName": "10204210370",
            "CharacterMotions": [],
            "SpeakerIconId": "205"
        },
        {
            "Id": 1020421042,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 42,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "『愛する者を引き裂くことは誰にもできない……』",
            "BackgroundImageFileName": "1590",
            "VoiceFileName": "10204210380",
            "CharacterMotions": [],
            "SpeakerIconId": "203"
        },
        {
            "Id": 1020421043,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 43,
            "SpeakerName": "大黒",
            "FontSize": 2,
            "Phrase": "『……聞いたわ。その言葉……』",
            "VoiceFileName": "10204210390",
            "CharacterMotions": [],
            "SpeakerIconId": "202"
        },
        {
            "Id": 1020421044,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 44,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "『……何っ！？』",
            "VoiceFileName": "10204210400",
            "CharacterMotions": [],
            "SpeakerIconId": "203"
        },
        {
            "Id": 1020421045,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 45,
            "SpeakerName": "容",
            "FontSize": 2,
            "Phrase": "『愛は引き裂けない……。/n　どれほどの力で分かたれようと……』",
            "VoiceFileName": "10204210410",
            "CharacterMotions": [],
            "SpeakerIconId": "204"
        },
        {
            "Id": 1020421046,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 46,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "『小部屋で眠りについていた人たちが……！？』",
            "VoiceFileName": "10204210420",
            "CharacterMotions": [],
            "SpeakerIconId": "205"
        },
        {
            "Id": 1020421047,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 47,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "『いったい……何が起きているのだ！？』",
            "VoiceFileName": "10204210430",
            "CharacterMotions": [],
            "SpeakerIconId": "201"
        },
        {
            "Id": 1020421048,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 48,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "『お……おぉっ……愛する我が妻たちよ……！/n　何故、お前たちがここに……！？』",
            "VoiceFileName": "10204210440",
            "CharacterMotions": [],
            "SpeakerIconId": "203"
        },
        {
            "Id": 1020421049,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 49,
            "SpeakerName": "大黒",
            "FontSize": 2,
            "Phrase": "『あなたが……私たちを導いてくれた……』",
            "VoiceFileName": "10204210450",
            "CharacterMotions": [],
            "SpeakerIconId": "202"
        },
        {
            "Id": 1020421050,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 50,
            "SpeakerName": "容",
            "FontSize": 2,
            "Phrase": "『あなたが、私たちを……繋ぎとめてくれた……』",
            "VoiceFileName": "10204210460",
            "CharacterMotions": [],
            "SpeakerIconId": "204"
        },
        {
            "Id": 1020421051,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 51,
            "SpeakerName": "大黒",
            "FontSize": 2,
            "Phrase": "『だから……さあ……行きましょう』",
            "VoiceFileName": "10204210470",
            "CharacterMotions": [],
            "SpeakerIconId": "202"
        },
        {
            "Id": 1020421052,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 52,
            "SpeakerName": "容",
            "FontSize": 2,
            "Phrase": "『私たちと共に……同じ場所へ……』",
            "VoiceFileName": "10204210480",
            "CharacterMotions": [],
            "SpeakerIconId": "204"
        },
        {
            "Id": 1020421053,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 53,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "『ま、まさか……放せっ！』",
            "VoiceFileName": "10204210490",
            "CharacterMotions": [],
            "SpeakerIconId": "203"
        },
        {
            "Id": 1020421054,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 54,
            "SpeakerName": "大黒",
            "FontSize": 2,
            "Phrase": "『放しはしない……永遠に……』",
            "VoiceFileName": "10204210500",
            "CharacterMotions": [],
            "SpeakerIconId": "202"
        },
        {
            "Id": 1020421055,
            "EpisodeMasterId": 1020421,
            "Order": 1,
            "GroupOrder": 55,
            "SpeakerName": "容",
            "FontSize": 2,
            "Phrase": "『引き裂けはしない……とこしえに……』",
