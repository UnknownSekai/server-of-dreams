    "EpisodeDetail": [
        {
            "Id": 34028001,
            "EpisodeType": 0,
            "CharacterId": null,
            "Description": "【Birthday Night】連尺野 初魅/n連尺野 初魅/n/n若くしてEdenを率いる天才であり、役者と脚本家を兼ねる20歳。/n我が道をゆく唯我独尊タイプにして、センス頼りの芝居を認めない厳しい指導者だが、面倒見はよく気に入った女の子へのスキンシップが激しい。/n/n年齢：20歳/n誕生日：5月30日/n身長：165cm/n趣味：女の子と遊ぶ/nセンス：抑制空間（ネゲートフィールド）/n自分が演じる舞台の中で、共演者のセンスを任意に使用不可能にできる。/nセンスに頼った小綺麗な演技をしている演者に対し、己のセンスでセンスを剥奪し、生身で、魂で演技するよう強制する。",
            "Order": 1
        },
        {
            "Id": 34028502,
            "EpisodeType": 5,
            "CharacterId": 201,
            "Description": "もう、こんな時間か……。",
            "Order": 2
        },
        {
            "Id": 34028503,
            "EpisodeType": 5,
            "CharacterId": 201,
            "Description": "（……そうか、今日は誕生日だったか。稽古を休みにしたから、/n　容たちにも会わなかったし、気づかなかったな）",
            "Order": 3
        },
        {
            "Id": 34028504,
            "EpisodeType": 5,
            "CharacterId": 201,
            "Description": "（この歳にもなると、誕生日もあまり気にすることも少なくなるものだな）",
            "Order": 4
        },
        {
            "Id": 34028505,
            "EpisodeType": 5,
            "CharacterId": 201,
            "Description": "久方ぶりに実家に帰ってみるか？　最近顔もあまり出していなかったしな……。",
            "Order": 5
        },
        {
            "Id": 34028506,
            "EpisodeType": 5,
            "CharacterId": null,
            "Description": "へぇ……あなたも、親孝行してるのね。",
            "Order": 6
        },
        {
            "Id": 34028507,
            "EpisodeType": 5,
            "CharacterId": 201,
            "Description": "っ！？　驚いた……望有か。/nこんなところで奇遇だな。",
            "Order": 7
        },
        {
            "Id": 34028508,
            "EpisodeType": 5,
            "CharacterId": 201,
            "Description": "それにしても、意外そうな口ぶりだな。",
            "Order": 8
        },
        {
            "Id": 34028509,
            "EpisodeType": 5,
            "CharacterId": null,
            "Description": "そうね、普段の言動から、/nそういったことを自分から口にするタイプではないと思っていたから。",
            "Order": 9
        },
        {
            "Id": 34028510,
            "EpisodeType": 5,
            "CharacterId": 201,
            "Description": "私だって親への感謝くらいする。/nそれに今日は私の誕生日なのでな、家族に顔を出すのも悪くないと思って。",
            "Order": 10
        },
        {
            "Id": 34028511,
            "EpisodeType": 5,
            "CharacterId": 201,
            "Description": "とはいえ、急に押し掛けるのも向こうに負担をかけてしまうかもしれないが……。",
            "Order": 11
        },
        {
            "Id": 34028512,
            "EpisodeType": 5,
            "CharacterId": null,
            "Description": "そう、あなた誕生日だったの。/n……そうね。この後、時間取れる？",
            "Order": 12
        },
        {
            "Id": 34028513,
            "EpisodeType": 5,
            "CharacterId": 201,
            "Description": "時間……？　あ、ああ。特に決まった用事があるわけでもないからな。/nなんだ？　まさか私を食事にでも誘ってくれるというのか？　だとすれば嬉しいが……。",
            "Order": 13
        },
        {
            "Id": 34028514,
            "EpisodeType": 5,
            "CharacterId": null,
            "Description": "そのまさかよ。",
            "Order": 14
        },
        {
            "Id": 34028515,
            "EpisodeType": 5,
            "CharacterId": 201,
            "Description": "なに……！？",
            "Order": 15
        },
        {
            "Id": 34028516,
            "EpisodeType": 5,
            "CharacterId": null,
            "Description": "先達の役者として、ご馳走してあげるわ。/n知らない仲でもないし。",
            "Order": 16
        },
        {
            "Id": 34028517,
            "EpisodeType": 5,
            "CharacterId": null,
            "Description": "それに会うたび、しつこく誘って来るあなたへの意趣返し。/nそれで、どう？",
            "Order": 17
        },
        {
            "Id": 34028518,
            "EpisodeType": 5,
            "CharacterId": 201,
            "Description": "ふふっ、せっかくの望有からのお誘いだ。/n乗らせてもらおう。",
            "Order": 18
        },
        {
            "Id": 34028519,
            "EpisodeType": 5,
            "CharacterId": 201,
            "Description": "お言葉に甘えて、世話になる……。/nふふ、良い夜になりそうだ。",
            "Order": 19
        }
    ]
}