        },
        {
            "Id": 1020420002,
            "EpisodeMasterId": 1020420,
            "Order": 1,
            "GroupOrder": 2,
            "SpeakerName": "ドイツの審査員Ｂ",
            "FontSize": 2,
            "Phrase": "世羅テトラ率いる移動劇団として一世を風靡していた頃の面影は、/n流石にないみたいですが……。",
            "VoiceFileName": "10204200020",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020420003,
            "EpisodeMasterId": 1020420,
            "Order": 1,
            "GroupOrder": 3,
            "SpeakerName": "ドイツの審査員Ｃ",
            "FontSize": 2,
            "Phrase": "現座長による追放騒動から、劇団がどう変わったのか。/n今日はお手並み拝見といきましょうか。",
            "VoiceFileName": "10204200030",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
