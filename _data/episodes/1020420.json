        {
            "Id": 1020420009,
            "EpisodeMasterId": 1020420,
            "Order": 1,
            "GroupOrder": 9,
            "SpeakerName": "取引先経営者",
            "FontSize": 2,
            "Phrase": "お忙しい中ありがとうございます、筆島さん。",
            "VoiceFileName": "10204200080",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020420010,
            "EpisodeMasterId": 1020420,
            "Order": 1,
            "GroupOrder": 10,
            "SpeakerName": "しぐれの父",
            "FontSize": 2,
            "Phrase": "こちらこそ、お招きいただきありがとうございます。/nしかし、まさか観劇にご招待いただくとは……。",
            "VoiceFileName": "10204200090",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020420011,
            "EpisodeMasterId": 1020420,
            "Order": 1,
            "GroupOrder": 11,
            "SpeakerName": "取引先経営者",
            "FontSize": 2,
            "Phrase": "毎度ありふれた会食では、商談に発展がないと思いましてね。/nたまには趣向を変えてみるのも手かなと。",
            "VoiceFileName": "10204200100",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020420012,
            "EpisodeMasterId": 1020420,
            "Order": 1,
            "GroupOrder": 12,
            "SpeakerName": "取引先経営者",
            "FontSize": 2,
            "Phrase": "……舞台芸術は筆島さんの好みには合いませんかな？",
            "VoiceFileName": "10204200110",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020420013,
            "EpisodeMasterId": 1020420,
            "Order": 1,
            "GroupOrder": 13,
            "SpeakerName": "しぐれの父",
            "FontSize": 2,
            "Phrase": "いえ、そのようなことは。/nただ私は演劇には疎いもので……。",
            "VoiceFileName": "10204200120",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020420014,
            "EpisodeMasterId": 1020420,
            "Order": 1,
            "GroupOrder": 14,
            "SpeakerName": "取引先経営者",
            "FontSize": 2,
            "Phrase": "では、せっかくの機会です。/n是非楽しんでいってください。",
            "VoiceFileName": "10204200130",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020420015,
            "EpisodeMasterId": 1020420,
            "Order": 1,
            "GroupOrder": 15,
            "SpeakerName": "取引先経営者",
            "FontSize": 2,
            "Phrase": "ここは最近、私が注目している劇団でしてね。/n劇場の案内です、どうぞ。",
            "VoiceFileName": "10204200140",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020420016,
            "EpisodeMasterId": 1020420,
            "Order": 1,
            "GroupOrder": 16,
            "SpeakerName": "しぐれの父",
            "FontSize": 2,
            "Phrase": "これはご丁寧に……ん？　Eden？",
            "VoiceFileName": "10204200150",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020420017,
            "EpisodeMasterId": 1020420,
            "Order": 1,
            "GroupOrder": 17,
            "SpeakerName": "取引先経営者",
            "FontSize": 2,
            "Phrase": "どうかなさいましたか？",
            "VoiceFileName": "10204200160",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020420018,
            "EpisodeMasterId": 1020420,
            "Order": 1,
            "GroupOrder": 18,
            "SpeakerName": "しぐれの父",
            "FontSize": 2,
            "Phrase": "いえ、その……私の記憶違いでなければ……、/n確か、ここは娘の所属している劇団です。",
            "VoiceFileName": "10204200170",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020420019,
            "EpisodeMasterId": 1020420,
            "Order": 1,
            "GroupOrder": 19,
            "SpeakerName": "取引先経営者",
            "FontSize": 2,
            "Phrase": "なんと、そうでしたか！",
            "VoiceFileName": "10204200180",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020420020,
            "EpisodeMasterId": 1020420,
            "Order": 1,
            "GroupOrder": 20,
            "SpeakerName": "取引先経営者",
            "FontSize": 2,
            "Phrase": "そういえば、演者のリストに『筆島』という姓が……。/nいやぁ、凄い偶然ですな。",
            "VoiceFileName": "10204200190",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020420021,
            "EpisodeMasterId": 1020420,
            "Order": 1,
            "GroupOrder": 21,
            "SpeakerName": "取引先経営者",
            "FontSize": 2,
            "Phrase": "芝居そのものもですが、筆島さんの娘さんのご活躍も見られるとは。/n楽しみですね。",
            "VoiceFileName": "10204200200",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020420022,
            "EpisodeMasterId": 1020420,
            "Order": 1,
            "GroupOrder": 22,
            "SpeakerName": "しぐれの父",
            "FontSize": 2,
            "Phrase": "は、はあ……。",
            "VoiceFileName": "10204200210",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
