        },
        {
            "Id": 142391004,
            "EpisodeMasterId": 142391,
            "Order": 1,
            "GroupOrder": 4,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "（チャンスがあるなら逃したくはない、だが……。/n　私の作ったEdenで、私の描く舞台を演じたい、か……）",
            "VoiceFileName": "1423910030",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 102,
                    "BodyMotionMasterId": 7,
                    "SpineId": 20103,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "201"
        },
        {
            "Id": 142391005,
            "EpisodeMasterId": 142391,
            "Order": 1,
            "GroupOrder": 5,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "（……なんとも愛らしい告白だな。/n　流石の私も、ハートを掴まれてしまったようだ）",
            "VoiceFileName": "1423910040",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 103,
                    "BodyMotionMasterId": 15,
                    "SpineId": 20103,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "201"
        },
        {
            "Id": 142391006,
            "EpisodeMasterId": 142391,
            "Order": 1,
            "GroupOrder": 6,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "（だが、まだ完全に心を奪われたわけではない。/n　私は、誰かひとりのものになる訳にはいかないからな）",
            "VoiceFileName": "1423910050",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 74,
                    "BodyMotionMasterId": 7,
                    "SpineId": 20103,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "201"
        },
        {
            "Id": 142391007,
            "EpisodeMasterId": 142391,
            "Order": 1,
            "GroupOrder": 7,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "（私が貫く信念は、私や双葉……そして何より、/n　Edenの皆が目指す、理想の舞台を叶える為の指針だ）",
            "VoiceFileName": "1423910060",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 107,
                    "BodyMotionMasterId": 14,
                    "SpineId": 20103,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "201"
        },
        {
            "Id": 142391008,
            "EpisodeMasterId": 142391,
            "Order": 1,
            "GroupOrder": 8,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "……とは思いながらも、やはりあんな話を聞いてしまってはな……。/nこのまま、という訳にもいかないだろう。",
            "VoiceFileName": "1423910070",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 73,
                    "BodyMotionMasterId": 11,
                    "LipSyncMasterId": 4,
                    "SpineId": 20103,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "201"
        },
        {
            "Id": 142391009,
            "EpisodeMasterId": 142391,
            "Order": 1,
            "GroupOrder": 9,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "（まさか、しぐれが今まであれほどの重荷を背負って、/n　舞台に立っていたとは……なにかあるとは思っていたが、そこまでとは）",
            "VoiceFileName": "1423910080",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 107,
                    "BodyMotionMasterId": 15,
                    "SpineId": 20103,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "201"
        },
        {
            "Id": 142391010,
            "EpisodeMasterId": 142391,
            "Order": 1,
            "GroupOrder": 10,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "（しぐれはEdenで役者を続けたいと言ってくれている。/n　かと言って、ご両親の言う事を無視はできないだろう）",
            "VoiceFileName": "1423910090",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 74,
                    "BodyMotionMasterId": 7,
                    "SpineId": 20103,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "201"
        },
        {
            "Id": 142391011,
            "EpisodeMasterId": 142391,
            "Order": 1,
            "GroupOrder": 11,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "（強制力がある……という事とは別に、ご両親の言い分はもっともだ。/n　役者が厳しい世界であるのは事実。いつ食べていけなくなるかも分からない）",
            "VoiceFileName": "1423910100",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 107,
                    "SpineId": 20103,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "201"
        },
        {
            "Id": 142391012,
            "EpisodeMasterId": 142391,
            "Order": 1,
            "GroupOrder": 12,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "（……私の両親は、私が銀河座へ入ると決めた時、/n　有り難いことに背中を押してはくれていたが……）",
            "VoiceFileName": "1423910110",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 400,
                    "BodyMotionMasterId": 15,
                    "SpineId": 20103,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "201"
        },
        {
            "Id": 142391013,
            "EpisodeMasterId": 142391,
            "Order": 1,
            "GroupOrder": 13,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "（実際、しぐれのご両親のように不安もあったに違いない。/n　だから、実績がなければ……という考えは、充分に理解出来る）",
            "VoiceFileName": "1423910120",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 79,
                    "HeadMotionMasterId": 1,
                    "BodyMotionMasterId": 13,
                    "SpineId": 20103,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "201"
        },
        {
            "Id": 142391014,
            "EpisodeMasterId": 142391,
            "Order": 1,
            "GroupOrder": 14,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "（ならば劇団の責任者として、我がEdenの役者の憂いを断つためにも、/n　実績となる『何か』を探そう。世界演劇リーグ以外の道でな）",
            "VoiceFileName": "1423910130",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 101,
                    "HeadMotionMasterId": 1,
                    "BodyMotionMasterId": 13,
                    "SpineId": 20103,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "201"
        },
        {
            "Id": 142391015,
            "EpisodeMasterId": 142391,
            "Order": 1,
            "GroupOrder": 15,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "（……しかし、演劇界が古い考えに囚われがちなのは分かっていたが……。/n　どれもこれも、似たり寄ったりな賞や大会ばかりだな……）",
            "VoiceFileName": "1423910140",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 73,
                    "BodyMotionMasterId": 7,
                    "SpineId": 20103,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "201"
        },
        {
            "Id": 142391016,
            "EpisodeMasterId": 142391,
            "Order": 1,
            "GroupOrder": 16,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "まったく、世界演劇リーグに右に倣えで小さく纏まって……。/n最新の演劇界の情報を載せた雑誌ですら、私の求めるものは見つからないのか。",
            "VoiceFileName": "1423910150",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 74,
                    "BodyMotionMasterId": 15,
                    "LipSyncMasterId": 4,
                    "SpineId": 20103,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "201"
        },
        {
            "Id": 142391017,
            "EpisodeMasterId": 142391,
            "Order": 1,
            "GroupOrder": 17,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "（もっと何かないのか……。/n　世界演劇リーグの評価に匹敵するほどの賞や大会は……）",
            "VoiceFileName": "1423910160",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 107,
                    "BodyMotionMasterId": 7,
                    "SpineId": 20103,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "201"
        },
        {
            "Id": 142391018,
            "EpisodeMasterId": 142391,
            "Order": 1,
            "GroupOrder": 18,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "（その上で、私たちEdenが狙うに相応しい、意義のあるものが――）",
            "VoiceFileName": "1423910170",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "BodyMotionMasterId": 13,
                    "SpineId": 20103,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "201"
        },
        {
            "Id": 142391019,
            "EpisodeMasterId": 142391,
            "Order": 1,
            "GroupOrder": 19,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "ん？　これは……『プロメテウス賞』の記事……。",
            "VoiceFileName": "1423910180",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 511,
                    "BodyMotionMasterId": 6,
                    "LipSyncMasterId": 4,
                    "SpineId": 20103,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "201"
        },
        {
            "Id": 142391020,
            "EpisodeMasterId": 142391,
            "Order": 1,
            "GroupOrder": 20,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "（『昨今の演劇界はセンス至上主義ですが、元々舞台とは、/n　役者個々人の個性と演技力、舞台装置や小道具などの情景描写……』）",
            "VoiceFileName": "1423910190",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 107,
                    "BodyMotionMasterId": 7,
                    "SpineId": 20103,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "201"
        },
        {
            "Id": 142391021,
            "EpisodeMasterId": 142391,
            "Order": 1,
            "GroupOrder": 21,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "（『そして脚本の相乗効果によってのみ、形作られるものであり……』）",
            "VoiceFileName": "1423910200",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "BodyMotionMasterId": 15,
                    "SpineId": 20103,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "201"
        },
        {
            "Id": 142391022,
            "EpisodeMasterId": 142391,
            "Order": 1,
            "GroupOrder": 22,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "ほう……なるほどな。",
            "VoiceFileName": "1423910210",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 103,
                    "BodyMotionMasterId": 7,
                    "LipSyncMasterId": 1,
                    "SpineId": 20103,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
