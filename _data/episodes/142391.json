            "EpisodeMasterId": 142391,
            "Order": 1,
            "GroupOrder": 25,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "（『今期のコンクールに応募される作品群も、/n　独創的且つ素晴らしい舞台であることを切に願う』か――）",
            "VoiceFileName": "1423910240",
            "CharacterMotions": [
