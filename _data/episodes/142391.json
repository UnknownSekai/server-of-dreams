            "SpeakerIconId": "201"
        },
        {
            "Id": 142391023,
            "EpisodeMasterId": 142391,
            "Order": 1,
            "GroupOrder": 23,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "（私もかねてより気にはなっていた賞だ……）",
            "VoiceFileName": "1423910220",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 74,
                    "BodyMotionMasterId": 13,
                    "SpineId": 20103,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "201"
        },
        {
            "Id": 142391024,
            "EpisodeMasterId": 142391,
            "Order": 1,
            "GroupOrder": 24,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "（何せこの『プロメテウス賞』に選ばれた劇団というのは、/n　どこも、私の理想とする舞台の形に近いところばかりだったからな）",
            "VoiceFileName": "1423910230",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 103,
                    "BodyMotionMasterId": 15,
                    "SpineId": 20103,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
